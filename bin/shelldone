#!/usr/bin/env bash
# shelldone - Terminal process completion notifier
# Usage: shelldone <command> [args...]
set -euo pipefail

# ── Temp file cleanup ──────────────────────────────────────────────────────
_SHELLDONE_TMPFILES=()
_shelldone_cleanup() {
  local f
  for f in "${_SHELLDONE_TMPFILES[@]+"${_SHELLDONE_TMPFILES[@]}"}"; do
    rm -f "$f" 2>/dev/null
  done
}
trap _shelldone_cleanup EXIT

# ── Marker constants ───────────────────────────────────────────────────────
readonly _SHELLDONE_MARKER_BEGIN="# >>> shelldone >>>"
readonly _SHELLDONE_MARKER_END="# <<< shelldone <<<"

# ── VERSION lookup (multi-path) ───────────────────────────────────────────
_shelldone_resolve_version() {
  local bin_path="$0"
  if command -v readlink &>/dev/null; then
    bin_path="$(readlink -f "$bin_path" 2>/dev/null || readlink "$bin_path" 2>/dev/null || echo "$bin_path")"
  fi
  local prefix
  prefix="$(cd "$(dirname "$bin_path")/.." && pwd)"

  local candidate
  for candidate in \
    "${prefix}/VERSION" \
    "${prefix}/share/shelldone/VERSION" \
    "/usr/share/shelldone/VERSION"; do
    if [[ -f "$candidate" ]]; then
      cat "$candidate"
      return
    fi
  done
  echo "1.0.0"
}

SHELLDONE_VERSION="$(_shelldone_resolve_version)"

# Resolve the lib directory (works whether installed or run from source)
_shelldone_resolve_lib() {
  local bin_path="$0"
  # Follow symlinks (portable)
  if command -v readlink &>/dev/null; then
    bin_path="$(readlink -f "$bin_path" 2>/dev/null || readlink "$bin_path" 2>/dev/null || echo "$bin_path")"
  fi
  local bin_dir
  bin_dir="$(cd "$(dirname "$bin_path")" && pwd)"

  # Try: <prefix>/lib/shelldone/ (package manager install)
  if [[ -f "${bin_dir}/../lib/shelldone/shelldone.sh" ]]; then
    echo "${bin_dir}/../lib/shelldone"
  # Try: <repo>/lib/ (running from source)
  elif [[ -f "${bin_dir}/../lib/shelldone.sh" ]]; then
    echo "${bin_dir}/../lib"
  else
    echo >&2 "shelldone: cannot find lib directory"
    exit 1
  fi
}

SHELLDONE_LIB="$(_shelldone_resolve_lib)"

# Resolve the hooks directory (works whether installed or run from source)
_shelldone_resolve_hooks() {
  local bin_path="$0"
  if command -v readlink &>/dev/null; then
    bin_path="$(readlink -f "$bin_path" 2>/dev/null || readlink "$bin_path" 2>/dev/null || echo "$bin_path")"
  fi
  local prefix
  prefix="$(cd "$(dirname "$bin_path")/.." && pwd)"

  # Try: <prefix>/share/shelldone/hooks/ (package manager install)
  if [[ -d "${prefix}/share/shelldone/hooks" ]]; then
    echo "${prefix}/share/shelldone/hooks"
  # Try: <repo>/hooks/ (running from source)
  elif [[ -d "${prefix}/hooks" ]]; then
    echo "${prefix}/hooks"
  else
    echo >&2 "shelldone: cannot find hooks directory"
    return 1
  fi
}

SHELLDONE_HOOKS="$(_shelldone_resolve_hooks)"

# ── TUI library ─────────────────────────────────────────────────────────────
if [[ -f "${SHELLDONE_LIB}/tui.sh" ]]; then
  source "${SHELLDONE_LIB}/tui.sh"
fi

# ── AI CLI Registry ──────────────────────────────────────────────────────────
# Parallel arrays (bash 3.2 compatible - no associative arrays)
# Index: 0=claude 1=codex 2=gemini 3=copilot 4=cursor 5=aider

_SHELLDONE_AI_NAMES=("claude" "codex" "gemini" "copilot" "cursor" "aider")
_SHELLDONE_AI_LABELS=("Claude Code" "Codex CLI" "Gemini CLI" "Copilot CLI" "Cursor" "Aider")
_SHELLDONE_AI_HOOKS=("claude-done.sh" "codex-done.sh" "gemini-done.sh" "copilot-done.sh" "cursor-done.sh" "")
_SHELLDONE_AI_CMDS=("claude" "codex" "gemini" "gh" "cursor" "aider")
_SHELLDONE_AI_SETTINGS=("$HOME/.claude/settings.json" "$HOME/.codex/config.json" "$HOME/.gemini/settings.json" "" "$HOME/.cursor/hooks.json" "")
_SHELLDONE_AI_CONFIGDIRS=("$HOME/.claude" "$HOME/.codex" "$HOME/.gemini" "$HOME/.github" "$HOME/.cursor" "")

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
  local shell="${1:-}"

  # Auto-detect shell if not specified
  if [[ -z "$shell" ]]; then
    local parent
    parent="$(ps -p $PPID -o comm= 2>/dev/null || echo "")"
    case "$parent" in
      *zsh*)  shell="zsh" ;;
      *bash*) shell="bash" ;;
      *)
        # Fall back to $SHELL
        case "${SHELL:-}" in
          *zsh)  shell="zsh" ;;
          *bash) shell="bash" ;;
          *)
            echo >&2 "shelldone: cannot detect shell. Usage: shelldone init [bash|zsh]"
            exit 1
            ;;
        esac
        ;;
    esac
  fi

  local lib_path
  lib_path="$(cd "$SHELLDONE_LIB" && pwd)"

  case "$shell" in
    zsh)
      cat <<INITEOF
# shelldone shell integration
export _SHELLDONE_LIB="${lib_path}"
source "${lib_path}/shelldone.sh"
source "${lib_path}/auto-notify.zsh"
INITEOF
      ;;
    bash)
      cat <<INITEOF
# shelldone shell integration
export _SHELLDONE_LIB="${lib_path}"
source "${lib_path}/shelldone.sh"
source "${lib_path}/auto-notify.bash"
INITEOF
      ;;
    *)
      echo >&2 "shelldone: unsupported shell '$shell'. Supported: bash, zsh"
      exit 1
      ;;
  esac
}

cmd_setup() {
  local action="${1:-}"

  case "$action" in
    claude-hook)  _setup_claude_hook ;;
    codex-hook)   _setup_codex_hook ;;
    gemini-hook)  _setup_gemini_hook ;;
    copilot-hook) _setup_copilot_hook ;;
    cursor-hook)  _setup_cursor_hook ;;
    ai-hooks)     _setup_ai_hooks ;;
    --quick|all)
      # Non-interactive: sensible defaults (original behavior)
      _setup_shell_init
      _setup_ai_hooks
      echo ""
      printf '\033[1;32m[shelldone]\033[0m Setup complete!\n'
      printf '\033[1;34m[shelldone]\033[0m Restart your shell or run: exec %s\n' "$(basename "$SHELL")"
      ;;
    --full)
      # Interactive, all phases shown
      SHELLDONE_NONINTERACTIVE="" _setup_wizard "advanced"
      ;;
    "")
      # Default: interactive wizard if tty, otherwise quick
      if _tui_is_interactive; then
        _setup_wizard ""
      else
        _setup_shell_init
        _setup_ai_hooks
        echo ""
        printf '\033[1;32m[shelldone]\033[0m Setup complete!\n'
        printf '\033[1;34m[shelldone]\033[0m Restart your shell or run: exec %s\n' "$(basename "$SHELL")"
      fi
      ;;
    *)
      echo >&2 "Usage: shelldone setup [--quick|--full|all|ai-hooks|<ai>-hook]"
      exit 1
      ;;
  esac
}

_setup_wizard() {
  local forced_mode="${1:-}"
  local mode="quick"

  # Capture config snapshot before wizard starts
  _setup_snapshot_before

  # Phase 1: Welcome & Mode
  _setup_phase_welcome
  if [[ -n "$forced_mode" ]]; then
    mode="$forced_mode"
  fi

  local total_phases=4
  case "$mode" in
    advanced)    total_phases=7 ;;
    reconfigure) total_phases=4 ;;
  esac

  local phase=1

  # Phase 2: Shell Integration (skip for reconfigure)
  if [[ "$mode" != "reconfigure" ]]; then
    phase=$((phase + 1))
    _tui_divider "Shell Integration"
    _tui_step "$phase" "$total_phases" "Shell integration"

    # Show which shell RCs currently have the shelldone block
    local _need_install=true
    local _zsh_has=false _bash_has=false
    if [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null; then
      _zsh_has=true
    fi
    if [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null; then
      _bash_has=true
    fi

    if $_zsh_has || $_bash_has; then
      local _rc_status=""
      $_zsh_has && _rc_status=".zshrc $(_tui_badge "configured" "green")"
      $_bash_has && _rc_status="${_rc_status:+$_rc_status  }.bashrc $(_tui_badge "configured" "green")"
      printf '  Currently: %s\n' "$_rc_status"
      if _tui_is_interactive; then
        if _tui_confirm "  Re-apply shell integration?"; then
          _setup_shell_init
        else
          _tui_info "Skipped shell integration"
        fi
      else
        _setup_shell_init
      fi
    else
      _setup_shell_init
    fi
  fi

  # Phase 3 (advanced): Notification Preferences
  if [[ "$mode" == "advanced" ]]; then
    phase=$((phase + 1))
    _tui_divider "Notification Preferences"
    _tui_step "$phase" "$total_phases" "Notification preferences"
    _setup_phase_preferences
  fi

  # Phase: External Channels (advanced or reconfigure)
  if [[ "$mode" == "advanced" ]] || [[ "$mode" == "reconfigure" ]]; then
    phase=$((phase + 1))
    _tui_divider "External Channels"
    _tui_step "$phase" "$total_phases" "External channels"
    _setup_phase_channels_advanced
  fi

  # Phase: AI Hooks
  phase=$((phase + 1))
  _tui_divider "AI CLI Hooks"
  _tui_step "$phase" "$total_phases" "AI CLI hooks"
  if [[ "$mode" == "advanced" ]] || [[ "$mode" == "reconfigure" ]]; then
    _setup_phase_ai_hooks_interactive
  else
    _setup_ai_hooks
  fi

  # Phase: Health Check
  phase=$((phase + 1))
  _tui_divider "Health Check"
  _tui_step "$phase" "$total_phases" "Health check"
  echo ""
  if _tui_is_interactive; then
    _tui_spinner "Running health check..." cmd_doctor 2>/dev/null || cmd_doctor 2>/dev/null || true
  else
    cmd_doctor 2>/dev/null || true
  fi

  # Summary
  _setup_snapshot_after
  _setup_phase_summary
}

_setup_phase_welcome() {
  local _sd_platform _sd_shell
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"
    printf '\n%sshelldone %s%s setup\n' "${_TUI_BOLD}" "$SHELLDONE_VERSION" "${_TUI_RESET}"
    printf '%sPlatform: %s | Shell: %s%s\n\n' "${_TUI_DIM}" "$_SHELLDONE_PLATFORM" "$(basename "${SHELL:-unknown}")" "${_TUI_RESET}"
  )

  # Mini-dashboard showing current installation status
  _tui_divider "Current Status"

  # Shell integration status
  local shell_status
  local shell_badge
  if { [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null; } || \
     { [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null; }; then
    shell_badge="$(_tui_badge "configured" "green")"
  else
    shell_badge="$(_tui_badge "not set" "dim")"
  fi
  _tui_kv "Shell integration" "$shell_badge"

  # Channel count
  local -a _ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
  local ch_count=0 ch_total=6
  local _ce
  for _ce in "${_ch_envs[@]}"; do
    [[ -n "${!_ce:-}" ]] && ch_count=$((ch_count + 1))
  done
  _tui_kv "Channels" "${ch_count} of ${ch_total}"

  # AI hooks detected count
  local ai_count=0 ai_total=0
  local _ai_i
  for _ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
    local _ai_hook="${_SHELLDONE_AI_HOOKS[$_ai_i]}"
    local _ai_cmd="${_SHELLDONE_AI_CMDS[$_ai_i]}"
    local _ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$_ai_i]}"
    [[ -z "$_ai_hook" ]] && continue
    if command -v "$_ai_cmd" &>/dev/null || [[ -n "$_ai_config_dir" && -d "$_ai_config_dir" ]]; then
      ai_total=$((ai_total + 1))
      local _ai_settings="${_SHELLDONE_AI_SETTINGS[$_ai_i]}"
      local _ai_name="${_SHELLDONE_AI_NAMES[$_ai_i]}"
      local _hook_installed=false
      if [[ "$_ai_name" == "copilot" ]]; then
        [[ -f "$HOME/.github/hooks/shelldone-session-end.json" ]] && _hook_installed=true
      elif [[ -n "$_ai_settings" && -f "$_ai_settings" ]]; then
        grep -q "${_ai_hook%.sh}" "$_ai_settings" 2>/dev/null && _hook_installed=true
      fi
      $_hook_installed && ai_count=$((ai_count + 1))
    fi
  done
  _tui_kv "AI hooks" "${ai_count} of ${ai_total} detected"
  echo ""

  if [[ -z "${1:-}" ]] && _tui_is_interactive; then
    local -a mode_options=("Quick (sensible defaults)" "Advanced (configure everything)")
    # Offer Reconfigure if already set up
    if [[ $ch_count -gt 0 ]] || [[ $ai_count -gt 0 ]]; then
      mode_options+=("Reconfigure (channels & hooks only)")
    fi
    _tui_select "Choose setup mode:" "${mode_options[@]}"
    case $_TUI_SELECTED_INDEX in
      1) mode="advanced" ;;
      2) mode="reconfigure" ;;
    esac
    echo ""
  fi
}

_setup_phase_preferences() {
  echo ""
  _tui_select "Auto-notify threshold:" "5 seconds" "10 seconds (default)" "30 seconds" "60 seconds"
  local threshold
  case $_TUI_SELECTED_INDEX in
    0) threshold=5 ;;
    1) threshold=10 ;;
    2) threshold=30 ;;
    3) threshold=60 ;;
  esac
  _config_set_value "SHELLDONE_THRESHOLD" "$threshold"
  _tui_ok "Threshold set to ${threshold}s"

  echo ""
  _tui_select "Notify on:" "All commands (default)" "Failures only" "Successes only"
  local filter
  case $_TUI_SELECTED_INDEX in
    0) filter="all" ;;
    1) filter="failure" ;;
    2) filter="success" ;;
  esac
  _config_set_value "SHELLDONE_NOTIFY_ON" "$filter"
  _tui_ok "Filter set to ${filter}"

  echo ""
  if _tui_confirm "Enable voice announcements (TTS)?" "default_no"; then
    _config_set_value "SHELLDONE_VOICE" "true"
    _tui_ok "Voice enabled"
  fi

  echo ""
  if _tui_confirm "Enable focus detection (suppress when terminal focused)?" "default_yes"; then
    _config_set_value "SHELLDONE_FOCUS_DETECT" "true"
  else
    _config_set_value "SHELLDONE_FOCUS_DETECT" "false"
  fi
  echo ""
}

_setup_phase_channels() {
  echo ""
  if _tui_confirm "Set up external notification channels (Slack, Discord, etc.)?" "default_no"; then
    local -a available=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
    local ch
    for ch in "${available[@]}"; do
      if _tui_confirm "  Configure ${ch}?" "default_no"; then
        _channel_setup "$ch"
      fi
    done
  else
    printf '  Tip: Run %sshelldone channel add slack%s later\n' "${_TUI_BOLD}" "${_TUI_RESET}"
  fi
  echo ""
}

# Channel dashboard for the advanced setup wizard
_channels_status_dashboard() {
  local -a ch_names=("Slack" "Discord" "Telegram" "Email" "WhatsApp" "Webhook")
  local -a ch_keys=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
  local -a ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")

  echo ""
  local i
  for i in "${!ch_names[@]}"; do
    local env_var="${ch_envs[$i]}"
    local badge
    if [[ -n "${!env_var:-}" ]]; then
      badge="$(_tui_badge "configured" "green")"
    else
      badge="$(_tui_badge "not set" "dim")"
    fi
    _tui_kv "${ch_names[$i]}" "$badge"
  done
  echo ""
}

_setup_phase_channels_advanced() {
  echo ""

  if ! _tui_is_interactive; then
    # Non-interactive: skip channel dashboard loop
    printf '  Tip: Run %sshelldone channel add slack%s to configure channels\n' "${_TUI_BOLD}" "${_TUI_RESET}"
    echo ""
    return 0
  fi

  local -a all_channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
  local -a ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")

  while true; do
    _channels_status_dashboard
    _tui_select "Choose an action:" "Add/reconfigure a channel" "Remove a channel" "Test a channel" "Continue to next step"

    case $_TUI_SELECTED_INDEX in
      0)
        # Add/reconfigure
        _tui_select "Select channel:" "Slack" "Discord" "Telegram" "Email" "WhatsApp" "Webhook"
        _channel_setup "${all_channels[$_TUI_SELECTED_INDEX]}"
        ;;
      1)
        # Remove - only show configured channels
        local -a configured=()
        local ci
        for ci in "${!all_channels[@]}"; do
          [[ -n "${!ch_envs[$ci]:-}" ]] && configured+=("${all_channels[$ci]}")
        done
        if [[ ${#configured[@]} -eq 0 ]]; then
          _tui_info "No channels configured to remove"
        else
          _tui_select "Remove which channel?" "${configured[@]}"
          _channel_remove "$_TUI_SELECTED"
        fi
        ;;
      2)
        # Test - only show configured channels
        local -a configured=()
        local ci
        for ci in "${!all_channels[@]}"; do
          [[ -n "${!ch_envs[$ci]:-}" ]] && configured+=("${all_channels[$ci]}")
        done
        if [[ ${#configured[@]} -eq 0 ]]; then
          _tui_info "No channels configured to test"
        else
          _tui_select "Test which channel?" "${configured[@]}"
          cmd_webhook test "$_TUI_SELECTED" || true
        fi
        ;;
      3)
        # Continue
        break
        ;;
    esac
  done
  echo ""
}

_setup_phase_ai_hooks_interactive() {
  # Build list of detected AI CLIs
  local -a detected_names=()
  local -a detected_labels=()
  local -a detected_indices=()
  local i

  echo ""
  for i in "${!_SHELLDONE_AI_NAMES[@]}"; do
    local name="${_SHELLDONE_AI_NAMES[$i]}"
    local label="${_SHELLDONE_AI_LABELS[$i]}"
    local hook="${_SHELLDONE_AI_HOOKS[$i]}"
    local cmd="${_SHELLDONE_AI_CMDS[$i]}"
    local config_dir="${_SHELLDONE_AI_CONFIGDIRS[$i]}"
    local settings="${_SHELLDONE_AI_SETTINGS[$i]}"

    [[ -z "$hook" ]] && continue

    if command -v "$cmd" &>/dev/null || [[ -n "$config_dir" && -d "$config_dir" ]]; then
      # Check if already installed
      local _hook_installed=false
      if [[ "$name" == "copilot" ]]; then
        [[ -f "$HOME/.github/hooks/shelldone-session-end.json" ]] && _hook_installed=true
      elif [[ -n "$settings" && -f "$settings" ]]; then
        grep -q "${hook%.sh}" "$settings" 2>/dev/null && _hook_installed=true
      fi

      local badge
      if $_hook_installed; then
        badge="$(_tui_badge "installed" "green")"
      else
        badge="$(_tui_badge "detected" "yellow")"
      fi
      _tui_kv "$label" "$badge"

      detected_names+=("$name")
      detected_labels+=("$label")
      detected_indices+=("$i")
    fi
  done

  if [[ ${#detected_names[@]} -eq 0 ]]; then
    _tui_info "No AI CLIs detected on this system"
    echo ""
    return 0
  fi

  echo ""
  _tui_multiselect "Select hooks to install:" "${detected_labels[@]}"

  # Install selected hooks
  local installed=0
  local total_selected=0
  local sel_idx
  for sel_idx in ${_TUI_MULTISELECTED_INDICES:-}; do
    total_selected=$((total_selected + 1))
  done

  if [[ $total_selected -eq 0 ]]; then
    _tui_info "No hooks selected"
    echo ""
    return 0
  fi

  local progress_i=0
  for sel_idx in ${_TUI_MULTISELECTED_INDICES:-}; do
    local ai_name="${detected_names[$sel_idx]}"
    local ai_label="${detected_labels[$sel_idx]}"
    progress_i=$((progress_i + 1))
    _tui_progress "$progress_i" "$total_selected" "Installing ${ai_label} hook"
    if "_setup_${ai_name}_hook" 2>/dev/null; then
      installed=$((installed + 1))
      _tui_ok "${ai_label} hook installed"
    else
      _tui_err "Failed to install ${ai_label} hook"
    fi
  done

  if [[ $installed -gt 0 ]]; then
    echo ""
    _tui_ok "$installed AI hook(s) installed"
  fi
  echo ""
}

_SETUP_SNAPSHOT_BEFORE=""
_SETUP_SNAPSHOT_AFTER=""

_setup_snapshot_before() {
  local -a ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
  local snap=""
  # Shell integration
  if { [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null; } || \
     { [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null; }; then
    snap="shell:yes"
  else
    snap="shell:no"
  fi
  # Channels
  local _ce
  for _ce in "${ch_envs[@]}"; do
    if [[ -n "${!_ce:-}" ]]; then
      snap="$snap ${_ce}:yes"
    else
      snap="$snap ${_ce}:no"
    fi
  done
  _SETUP_SNAPSHOT_BEFORE="$snap"
}

_setup_snapshot_after() {
  local -a ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
  local snap=""
  if { [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null; } || \
     { [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null; }; then
    snap="shell:yes"
  else
    snap="shell:no"
  fi
  local _ce
  for _ce in "${ch_envs[@]}"; do
    if [[ -n "${!_ce:-}" ]]; then
      snap="$snap ${_ce}:yes"
    else
      snap="$snap ${_ce}:no"
    fi
  done
  _SETUP_SNAPSHOT_AFTER="$snap"
}

_setup_diff_summary() {
  local before="$_SETUP_SNAPSHOT_BEFORE"
  local after="$_SETUP_SNAPSHOT_AFTER"
  local changes=0

  # Compare each item
  local -a before_items after_items
  read -ra before_items <<< "$before"
  read -ra after_items <<< "$after"

  local i
  for i in "${!before_items[@]}"; do
    if [[ "${before_items[$i]}" != "${after_items[$i]:-}" ]]; then
      local key="${before_items[$i]%%:*}"
      local old_val="${before_items[$i]#*:}"
      local new_val="${after_items[$i]#*:}"
      if [[ "$old_val" == "no" && "$new_val" == "yes" ]]; then
        printf '    %s+ %s%s\n' "${_TUI_GREEN}" "$key" "${_TUI_RESET}"
        changes=$((changes + 1))
      elif [[ "$old_val" == "yes" && "$new_val" == "no" ]]; then
        printf '    %s- %s%s\n' "${_TUI_RED}" "$key" "${_TUI_RESET}"
        changes=$((changes + 1))
      fi
    fi
  done
  return $changes
}

_setup_phase_summary() {
  echo ""
  _tui_divider "Summary"
  _tui_header "Setup complete!"
  echo ""

  # Show current status dashboard
  local shell_badge
  if { [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null; } || \
     { [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null; }; then
    shell_badge="$(_tui_badge "configured" "green")"
  else
    shell_badge="$(_tui_badge "not set" "dim")"
  fi
  _tui_kv "Shell integration" "$shell_badge"

  # Channels
  local -a ch_names=("Slack" "Discord" "Telegram" "Email" "WhatsApp" "Webhook")
  local -a ch_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
  local ch_configured=0
  local ci
  for ci in "${!ch_names[@]}"; do
    if [[ -n "${!ch_envs[$ci]:-}" ]]; then
      ch_configured=$((ch_configured + 1))
    fi
  done
  _tui_kv "Channels" "${ch_configured} configured"

  # AI hooks summary
  local hook_count=0
  local _ai_i
  for _ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
    local _ai_hook="${_SHELLDONE_AI_HOOKS[$_ai_i]}"
    local _ai_cmd="${_SHELLDONE_AI_CMDS[$_ai_i]}"
    local _ai_name="${_SHELLDONE_AI_NAMES[$_ai_i]}"
    local _ai_settings="${_SHELLDONE_AI_SETTINGS[$_ai_i]}"
    local _ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$_ai_i]}"
    [[ -z "$_ai_hook" ]] && continue
    if command -v "$_ai_cmd" &>/dev/null || [[ -n "$_ai_config_dir" && -d "$_ai_config_dir" ]]; then
      local _hi=false
      if [[ "$_ai_name" == "copilot" ]]; then
        [[ -f "$HOME/.github/hooks/shelldone-session-end.json" ]] && _hi=true
      elif [[ -n "$_ai_settings" && -f "$_ai_settings" ]]; then
        grep -q "${_ai_hook%.sh}" "$_ai_settings" 2>/dev/null && _hi=true
      fi
      $_hi && hook_count=$((hook_count + 1))
    fi
  done
  _tui_kv "AI hooks" "${hook_count} installed"

  # Show diff if snapshots were taken
  if [[ -n "$_SETUP_SNAPSHOT_BEFORE" && -n "$_SETUP_SNAPSHOT_AFTER" ]]; then
    if [[ "$_SETUP_SNAPSHOT_BEFORE" != "$_SETUP_SNAPSHOT_AFTER" ]]; then
      echo ""
      printf '  %sChanges this session:%s\n' "${_TUI_BOLD}" "${_TUI_RESET}"
      _setup_diff_summary || true
    fi
  fi

  echo ""
  echo "  Next steps:"
  printf '    1. Restart your shell: %sexec %s%s\n' "${_TUI_BOLD}" "$(basename "$SHELL")" "${_TUI_RESET}"
  printf '    2. Try it out:         %salert sleep 2%s\n' "${_TUI_BOLD}" "${_TUI_RESET}"
  printf '    3. Check status:       %sshelldone status%s\n' "${_TUI_BOLD}" "${_TUI_RESET}"
  echo ""
}

_setup_shell_init() {
  local bin_path bin_dir
  bin_path="$(cd "$(dirname "$0")" && pwd)/shelldone"
  bin_dir="$(dirname "$bin_path")"

  # Legacy marker constants (for migration from cli-alert)
  local _OLD_MARKER_BEGIN="# >>> cli-alert >>>"
  local _OLD_MARKER_END="# <<< cli-alert <<<"

  _remove_old_block() {
    local rc_file="$1"
    [[ -f "$rc_file" ]] || return 0
    grep -qF "$_OLD_MARKER_BEGIN" "$rc_file" 2>/dev/null || return 0

    local tmp_file
    tmp_file=$(mktemp)
    _SHELLDONE_TMPFILES+=("$tmp_file")
    local in_block=0
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "$_OLD_MARKER_BEGIN" ]]; then
        in_block=1; continue
      fi
      if [[ "$line" == "$_OLD_MARKER_END" ]]; then
        in_block=0; continue
      fi
      if [[ $in_block -eq 0 ]]; then
        printf '%s\n' "$line" >> "$tmp_file"
      fi
    done < "$rc_file"
    mv "$tmp_file" "$rc_file"
    printf '\033[1;33m[shelldone]\033[0m Removed old cli-alert block from %s\n' "$(basename "$rc_file")"
  }

  _add_to_rc() {
    local rc_file="$1" shell_name="$2"

    # Migrate: remove old cli-alert block first
    _remove_old_block "$rc_file"

    if grep -qF "$_SHELLDONE_MARKER_BEGIN" "$rc_file" 2>/dev/null; then
      printf '\033[1;34m[shelldone]\033[0m Already in %s, skipping\n' "$(basename "$rc_file")"
      return 0
    fi

    {
      echo ""
      echo "$_SHELLDONE_MARKER_BEGIN"
      echo "export PATH=\"${bin_dir}:\$PATH\""
      echo "eval \"\$(${bin_path} init ${shell_name})\""
      echo "$_SHELLDONE_MARKER_END"
    } >> "$rc_file"

    printf '\033[1;32m[shelldone]\033[0m Added to %s\n' "$rc_file"
  }

  # Migrate config directory: ~/.config/cli-alert → ~/.config/shelldone
  local old_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/cli-alert"
  local new_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/shelldone"
  if [[ -d "$old_config_dir" ]] && [[ ! -d "$new_config_dir" ]]; then
    mkdir -p "$new_config_dir"
    cp -a "$old_config_dir"/* "$new_config_dir"/ 2>/dev/null || true
    printf '\033[1;33m[shelldone]\033[0m Migrated config from %s -> %s\n' "$old_config_dir" "$new_config_dir"
  fi

  # Detect which rc files to modify
  if [[ -f "$HOME/.zshrc" ]] || [[ "$(basename "${SHELL:-}" 2>/dev/null)" == "zsh" ]]; then
    _add_to_rc "$HOME/.zshrc" "zsh"
  fi
  if [[ -f "$HOME/.bashrc" ]] || [[ "$(basename "${SHELL:-}" 2>/dev/null)" == "bash" ]]; then
    _add_to_rc "$HOME/.bashrc" "bash"
  fi
}

_setup_claude_hook() {
  local done_cmd="${SHELLDONE_HOOKS}/claude-done.sh"
  local notify_cmd="${SHELLDONE_HOOKS}/claude-notify.sh"
  local claude_settings="$HOME/.claude/settings.json"

  if [[ ! -f "$done_cmd" ]]; then
    echo >&2 "shelldone: hook script not found at $done_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[shelldone]\033[0m python3 not found - skipping Claude Code hook\n'
    printf '\033[1;33m[shelldone]\033[0m Manually add to %s\n' "$claude_settings"
    return 0
  fi

  if [[ ! -f "$claude_settings" ]]; then
    mkdir -p "$(dirname "$claude_settings")"
    echo '{}' > "$claude_settings"
  fi

  local result
  result=$(python3 - "$claude_settings" "$done_cmd" "$notify_cmd" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
done_cmd = sys.argv[2]
notify_cmd = sys.argv[3]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", {})
installed = []

for event_key, cmd in [("Stop", done_cmd), ("Notification", notify_cmd)]:
    event_hooks = hooks.setdefault(event_key, [])
    already = False
    for entry in event_hooks:
        for h in entry.get("hooks", []):
            if h.get("command", "") == cmd:
                already = True
                break
        if already:
            break
    if already:
        installed.append("ALREADY:" + event_key)
    else:
        hook_entry = {"hooks": [{"type": "command", "command": cmd}]}
        event_hooks.append(hook_entry)
        installed.append("INSTALLED:" + event_key)

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

for item in installed:
    print(item)
PYEOF
  )

  while IFS= read -r line; do
    case "$line" in
      ALREADY:Stop)
        printf '\033[1;34m[shelldone]\033[0m Claude Code Stop hook already installed\n' ;;
      INSTALLED:Stop)
        printf '\033[1;32m[shelldone]\033[0m Added Claude Code Stop hook\n' ;;
      ALREADY:Notification)
        printf '\033[1;34m[shelldone]\033[0m Claude Code Notification hook already installed\n' ;;
      INSTALLED:Notification)
        printf '\033[1;32m[shelldone]\033[0m Added Claude Code Notification hook\n' ;;
    esac
  done <<< "$result"
}

_setup_codex_hook() {
  local done_cmd="${SHELLDONE_HOOKS}/codex-done.sh"
  local codex_config="$HOME/.codex/config.toml"

  if [[ ! -f "$done_cmd" ]]; then
    echo >&2 "shelldone: hook script not found at $done_cmd"
    return 1
  fi

  mkdir -p "$(dirname "$codex_config")"

  # Check if notify is already configured in config.toml
  if [[ -f "$codex_config" ]] && grep -q "$done_cmd" "$codex_config" 2>/dev/null; then
    printf '\033[1;34m[shelldone]\033[0m Codex CLI notify hook already installed\n'
  else
    # Remove any existing notify line, then append the new one
    if [[ -f "$codex_config" ]]; then
      local tmp="${codex_config}.shelldone.tmp"
      grep -v '^notify\s*=' "$codex_config" > "$tmp" 2>/dev/null || true
      mv "$tmp" "$codex_config"
    fi
    # Append notify entry
    printf '\nnotify = ["%s"]\n' "$done_cmd" >> "$codex_config"
    printf '\033[1;32m[shelldone]\033[0m Added Codex CLI notify hook\n'
  fi

  printf '\033[1;33m[shelldone]\033[0m Note: Codex CLI only supports agent-turn-complete notifications.\n'
  printf '\033[1;33m[shelldone]\033[0m "Waiting for input" alerts are not supported by Codex CLI.\n'

  # Clean up stale config.json if it has shelldone hooks
  local stale_json="$HOME/.codex/config.json"
  if [[ -f "$stale_json" ]] && grep -q "codex-done.sh\|codex-notify.sh" "$stale_json" 2>/dev/null; then
    if command -v python3 &>/dev/null; then
      python3 - "$stale_json" << 'PYEOF'
import sys, json
path = sys.argv[1]
with open(path, 'r') as f:
    config = json.load(f)
if "hooks" in config:
    del config["hooks"]
    with open(path, 'w') as f:
        json.dump(config, f, indent=2)
PYEOF
    fi
  fi
}

_setup_gemini_hook() {
  local done_cmd="${SHELLDONE_HOOKS}/gemini-done.sh"
  local notify_cmd="${SHELLDONE_HOOKS}/gemini-notify.sh"
  local gemini_settings="$HOME/.gemini/settings.json"

  if [[ ! -f "$done_cmd" ]]; then
    echo >&2 "shelldone: hook script not found at $done_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[shelldone]\033[0m python3 not found - skipping Gemini CLI hook\n'
    printf '\033[1;33m[shelldone]\033[0m Manually add to %s\n' "$gemini_settings"
    return 0
  fi

  if [[ ! -f "$gemini_settings" ]]; then
    mkdir -p "$(dirname "$gemini_settings")"
    echo '{}' > "$gemini_settings"
  fi

  local result
  result=$(python3 - "$gemini_settings" "$done_cmd" "$notify_cmd" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
done_cmd = sys.argv[2]
notify_cmd = sys.argv[3]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", [])
installed = []

for event_name, cmd in [("turn_end", done_cmd), ("notification", notify_cmd)]:
    already = False
    for entry in hooks:
        if entry.get("command", "") == cmd:
            already = True
            break
    if already:
        installed.append("ALREADY:" + event_name)
    else:
        hook_entry = {"type": "command", "command": cmd, "event": event_name}
        hooks.append(hook_entry)
        installed.append("INSTALLED:" + event_name)

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

for item in installed:
    print(item)
PYEOF
  )

  while IFS= read -r line; do
    case "$line" in
      ALREADY:turn_end)
        printf '\033[1;34m[shelldone]\033[0m Gemini CLI hook already installed\n' ;;
      INSTALLED:turn_end)
        printf '\033[1;32m[shelldone]\033[0m Added Gemini CLI hook\n' ;;
      ALREADY:notification)
        printf '\033[1;34m[shelldone]\033[0m Gemini CLI Notification hook already installed\n' ;;
      INSTALLED:notification)
        printf '\033[1;32m[shelldone]\033[0m Added Gemini CLI Notification hook\n' ;;
    esac
  done <<< "$result"
}

_setup_copilot_hook() {
  local done_cmd="${SHELLDONE_HOOKS}/copilot-done.sh"
  local hooks_dir="$HOME/.github/hooks"
  local done_file="${hooks_dir}/shelldone-session-end.json"

  if [[ ! -f "$done_cmd" ]]; then
    echo >&2 "shelldone: hook script not found at $done_cmd"
    return 1
  fi

  mkdir -p "$hooks_dir"

  # sessionEnd hook
  if [[ -f "$done_file" ]] && grep -q "$done_cmd" "$done_file" 2>/dev/null; then
    printf '\033[1;34m[shelldone]\033[0m Copilot CLI sessionEnd hook already installed\n'
  else
    cat > "$done_file" << JSONEOF
{
  "event": "sessionEnd",
  "command": "$done_cmd"
}
JSONEOF
    printf '\033[1;32m[shelldone]\033[0m Added Copilot CLI sessionEnd hook\n'
  fi

  printf '\033[1;33m[shelldone]\033[0m Note: Copilot CLI only supports sessionEnd notifications.\n'
  printf '\033[1;33m[shelldone]\033[0m "Waiting for input" alerts are not supported by Copilot CLI.\n'

  # Clean up stale notification hook file if it exists
  local stale_notify="${hooks_dir}/shelldone-notification.json"
  if [[ -f "$stale_notify" ]]; then
    rm -f "$stale_notify"
  fi
}

_setup_cursor_hook() {
  local done_cmd="${SHELLDONE_HOOKS}/cursor-done.sh"
  local cursor_hooks="$HOME/.cursor/hooks.json"

  if [[ ! -f "$done_cmd" ]]; then
    echo >&2 "shelldone: hook script not found at $done_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[shelldone]\033[0m python3 not found - skipping Cursor hook\n'
    printf '\033[1;33m[shelldone]\033[0m Manually add to %s\n' "$cursor_hooks"
    return 0
  fi

  if [[ ! -f "$cursor_hooks" ]]; then
    mkdir -p "$(dirname "$cursor_hooks")"
    echo '{}' > "$cursor_hooks"
  fi

  local result
  result=$(python3 - "$cursor_hooks" "$done_cmd" << 'PYEOF'
import sys, json

hooks_path = sys.argv[1]
done_cmd = sys.argv[2]

with open(hooks_path, 'r') as f:
    config = json.load(f)

installed = []

# Only register "stop" hook (Cursor does not support "notification" event)
event_hooks = config.setdefault("stop", [])
already = False
for entry in event_hooks:
    if entry.get("command", "") == done_cmd:
        already = True
        break
if already:
    installed.append("ALREADY:stop")
else:
    hook_entry = {"type": "command", "command": done_cmd}
    event_hooks.append(hook_entry)
    installed.append("INSTALLED:stop")

# Clean up stale notification hook if it exists
if "notification" in config:
    del config["notification"]

with open(hooks_path, 'w') as f:
    json.dump(config, f, indent=2)

for item in installed:
    print(item)
PYEOF
  )

  while IFS= read -r line; do
    case "$line" in
      ALREADY:stop)
        printf '\033[1;34m[shelldone]\033[0m Cursor stop hook already installed\n' ;;
      INSTALLED:stop)
        printf '\033[1;32m[shelldone]\033[0m Added Cursor stop hook\n' ;;
    esac
  done <<< "$result"

  printf '\033[1;33m[shelldone]\033[0m Note: Cursor only supports stop notifications.\n'
  printf '\033[1;33m[shelldone]\033[0m "Waiting for input" alerts are not supported by Cursor.\n'
}

_setup_ai_hooks() {
  local i installed=0 skipped=0

  for i in "${!_SHELLDONE_AI_NAMES[@]}"; do
    local name="${_SHELLDONE_AI_NAMES[$i]}"
    local label="${_SHELLDONE_AI_LABELS[$i]}"
    local hook="${_SHELLDONE_AI_HOOKS[$i]}"
    local cmd="${_SHELLDONE_AI_CMDS[$i]}"
    local config_dir="${_SHELLDONE_AI_CONFIGDIRS[$i]}"

    # Skip Aider (no hooks)
    if [[ -z "$hook" ]]; then
      if command -v "$cmd" &>/dev/null; then
        printf '\033[1;34m[shelldone]\033[0m %s detected - no native hooks, use: alert aider <prompt>\n' "$label"
      fi
      continue
    fi

    # Check if the AI CLI is installed (command exists or config dir exists)
    if command -v "$cmd" &>/dev/null || [[ -n "$config_dir" && -d "$config_dir" ]]; then
      "_setup_${name}_hook" && installed=$((installed + 1)) || true
    else
      skipped=$((skipped + 1))
    fi
  done

  if [[ $installed -gt 0 || $skipped -gt 0 ]]; then
    printf '\033[1;34m[shelldone]\033[0m AI hooks: %d installed, %d skipped (not detected)\n' "$installed" "$skipped"
  fi
}

cmd_test() {
  local test_script
  test_script="$(cd "$(dirname "$0")/.." && pwd)/test.sh"
  if [[ -x "$test_script" ]]; then
    exec "$test_script"
  else
    echo >&2 "shelldone: test script not found"
    exit 1
  fi
}

cmd_uninstall() {
  # Check for --yes/-y flag
  local skip_confirm=false
  case "${1:-}" in
    --yes|-y) skip_confirm=true ;;
  esac

  if ! $skip_confirm && _tui_is_interactive; then
    if ! _tui_confirm "This will remove shelldone from .zshrc, .bashrc, and all AI CLI hooks. Continue?"; then
      echo "Cancelled."
      return 0
    fi
  fi

  # Legacy marker constants (for cleaning up old cli-alert blocks)
  local _OLD_MARKER_BEGIN="# >>> cli-alert >>>"
  local _OLD_MARKER_END="# <<< cli-alert <<<"

  _remove_from_rc() {
    local rc_file="$1"

    [[ ! -f "$rc_file" ]] && return 0

    local has_new has_old
    has_new=0; has_old=0
    grep -qF "$_SHELLDONE_MARKER_BEGIN" "$rc_file" 2>/dev/null && has_new=1
    grep -qF "$_OLD_MARKER_BEGIN" "$rc_file" 2>/dev/null && has_old=1

    if [[ $has_new -eq 0 ]] && [[ $has_old -eq 0 ]]; then
      printf '\033[1;34m[shelldone]\033[0m Not in %s, skipping\n' "$(basename "$rc_file")"
      return 0
    fi

    local tmp_file
    tmp_file=$(mktemp)
    _SHELLDONE_TMPFILES+=("$tmp_file")
    local in_block=0
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "$_SHELLDONE_MARKER_BEGIN" ]] || [[ "$line" == "$_OLD_MARKER_BEGIN" ]]; then
        in_block=1; continue
      fi
      if [[ "$line" == "$_SHELLDONE_MARKER_END" ]] || [[ "$line" == "$_OLD_MARKER_END" ]]; then
        in_block=0; continue
      fi
      if [[ $in_block -eq 0 ]]; then
        printf '%s\n' "$line" >> "$tmp_file"
      fi
    done < "$rc_file"

    mv "$tmp_file" "$rc_file"
    printf '\033[1;32m[shelldone]\033[0m Removed from %s\n' "$rc_file"
  }

  _remove_from_rc "$HOME/.zshrc"
  _remove_from_rc "$HOME/.bashrc"

  # Remove Claude hook from ~/.claude/settings.json
  _uninstall_json_hook() {
    local settings_file="$1" hook_cmd="$2" label="$3" hook_key="${4:-Stop}"

    [[ -f "$settings_file" ]] || return 0
    command -v python3 &>/dev/null || return 0

    python3 - "$settings_file" "$hook_cmd" "$hook_key" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
hook_cmd = sys.argv[2]
hook_key = sys.argv[3]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.get("hooks", {})

if isinstance(hooks, dict):
    stop_hooks = hooks.get(hook_key, [])
    new_stop = []
    removed = False
    for entry in stop_hooks:
        if isinstance(entry, dict) and "hooks" in entry:
            entry_hooks = entry.get("hooks", [])
            filtered = [h for h in entry_hooks if h.get("command", "") != hook_cmd]
            if len(filtered) < len(entry_hooks):
                removed = True
            if filtered:
                entry["hooks"] = filtered
                new_stop.append(entry)
        elif isinstance(entry, dict) and entry.get("command", "") == hook_cmd:
            removed = True
        else:
            new_stop.append(entry)
    if removed:
        if new_stop:
            hooks[hook_key] = new_stop
        else:
            hooks.pop(hook_key, None)
        if not hooks:
            settings.pop("hooks", None)
        with open(settings_path, 'w') as f:
            json.dump(settings, f, indent=2)
elif isinstance(hooks, list):
    new_hooks = [h for h in hooks if h.get("command", "") != hook_cmd]
    if len(new_hooks) < len(hooks):
        removed = True
        if new_hooks:
            settings["hooks"] = new_hooks
        else:
            settings.pop("hooks", None)
        with open(settings_path, 'w') as f:
            json.dump(settings, f, indent=2)
PYEOF
    printf '\033[1;32m[shelldone]\033[0m Removed %s hook\n' "$label"
  }

  # Remove Claude Code hooks
  _uninstall_json_hook "$HOME/.claude/settings.json" "${SHELLDONE_HOOKS}/claude-done.sh" "Claude Code" "Stop"
  _uninstall_json_hook "$HOME/.claude/settings.json" "${SHELLDONE_HOOKS}/claude-notify.sh" "Claude Code" "Notification"

  # Remove Codex CLI hooks (TOML config)
  local codex_config="$HOME/.codex/config.toml"
  if [[ -f "$codex_config" ]] && grep -q "${SHELLDONE_HOOKS}/codex-done.sh" "$codex_config" 2>/dev/null; then
    local tmp="${codex_config}.shelldone.tmp"
    grep -v "codex-done.sh" "$codex_config" > "$tmp" 2>/dev/null || true
    mv "$tmp" "$codex_config"
    printf '\033[1;32m[shelldone]\033[0m Removed Codex CLI notify hook\n'
  fi
  # Also clean up stale JSON hooks if present
  local codex_json="$HOME/.codex/config.json"
  if [[ -f "$codex_json" ]] && grep -q "codex-done.sh\|codex-notify.sh" "$codex_json" 2>/dev/null; then
    _uninstall_json_hook "$codex_json" "${SHELLDONE_HOOKS}/codex-done.sh" "Codex CLI" "Stop"
    _uninstall_json_hook "$codex_json" "${SHELLDONE_HOOKS}/codex-notify.sh" "Codex CLI" "Notification"
  fi

  # Remove Gemini CLI hooks
  _uninstall_json_hook "$HOME/.gemini/settings.json" "${SHELLDONE_HOOKS}/gemini-done.sh" "Gemini CLI" "hooks"
  _uninstall_json_hook "$HOME/.gemini/settings.json" "${SHELLDONE_HOOKS}/gemini-notify.sh" "Gemini CLI" "hooks"

  # Remove Copilot CLI hooks
  local copilot_hook_file="$HOME/.github/hooks/shelldone-session-end.json"
  if [[ -f "$copilot_hook_file" ]]; then
    rm -f "$copilot_hook_file"
    printf '\033[1;32m[shelldone]\033[0m Removed Copilot CLI hook\n'
  fi
  local copilot_notify_file="$HOME/.github/hooks/shelldone-notification.json"
  if [[ -f "$copilot_notify_file" ]]; then
    rm -f "$copilot_notify_file"
    printf '\033[1;32m[shelldone]\033[0m Removed Copilot CLI Notification hook\n'
  fi

  # Remove Cursor hooks
  _uninstall_json_hook "$HOME/.cursor/hooks.json" "${SHELLDONE_HOOKS}/cursor-done.sh" "Cursor" "stop"

  echo ""
  printf '\033[1;32m[shelldone]\033[0m Uninstalled! Restart your shell to apply.\n'
}

cmd_version() {
  echo "shelldone $SHELLDONE_VERSION"
  if [[ "${1:-}" == "--verbose" || "${1:-}" == "-v" ]]; then
    (
      unset _SHELLDONE_LOADED
      source "${SHELLDONE_LIB}/shelldone.sh"
      echo "  platform: $_SHELLDONE_PLATFORM"
    )
    echo "  shell:    $(basename "${SHELL:-unknown}")"
    echo "  path:     $(cd "$(dirname "$0")" && pwd)/shelldone"
  fi
}

_status_mute_countdown() {
  local ts="$1" now="$2"
  if [[ "$ts" == "0" ]]; then
    printf 'indefinite'
    return
  fi
  local remaining=$(( ts - now ))
  if (( remaining <= 0 )); then
    return 1
  elif (( remaining >= 3600 )); then
    printf '%dh %dm left' $(( remaining / 3600 )) $(( (remaining % 3600) / 60 ))
  elif (( remaining >= 60 )); then
    printf '%dm left' $(( remaining / 60 ))
  else
    printf '%ds left' "$remaining"
  fi
}

_status_channel_state() {
  local channel="$1" is_configured="$2" now="$3"

  # Not configured?
  if [[ "$is_configured" != "true" ]]; then
    printf '%s-%s not configured\n' "${_TUI_DIM:-}" "${_TUI_RESET:-}"
    return
  fi

  # Toggled off?
  local toggle_val
  toggle_val="$(_shelldone_state_read "$channel" 2>/dev/null)" || toggle_val=""
  if [[ "$toggle_val" == "off" ]]; then
    printf '%s✗%s toggled off\n' "${_TUI_RED:-}" "${_TUI_RESET:-}"
    return
  fi

  # Per-channel muted?
  local ch_mute_until
  if ch_mute_until="$(_shelldone_state_read "mute_${channel}_until" 2>/dev/null)"; then
    local countdown
    if countdown="$(_status_mute_countdown "$ch_mute_until" "$now")"; then
      printf '%s!%s muted (%s)\n' "${_TUI_YELLOW:-}" "${_TUI_RESET:-}" "$countdown"
      return
    fi
  fi

  # Active
  printf '%s✓%s on\n' "${_TUI_GREEN:-}" "${_TUI_RESET:-}"
}

_status_channel_dashboard() {
  # Load TUI colors if available
  if ! declare -f _tui_init_colors &>/dev/null; then
    local _tui_lib="${SHELLDONE_LIB}/tui.sh"
    [[ -f "$_tui_lib" ]] && source "$_tui_lib"
  fi

  local now; now=$(date +%s)

  printf '  %s── Local ─────────────────────%s\n' "${_TUI_DIM:-}" "${_TUI_RESET:-}"
  local local_ch
  for local_ch in desktop sound voice; do
    printf '    %-14s ' "$local_ch"
    _status_channel_state "$local_ch" "true" "$now"
  done

  printf '  %s── External ──────────────────%s\n' "${_TUI_DIM:-}" "${_TUI_RESET:-}"
  local -a ext_names=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
  local -a ext_envs=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
  local ei
  for ei in "${!ext_names[@]}"; do
    local ename="${ext_names[$ei]}" eenv="${ext_envs[$ei]}"
    local configured="false"
    [[ -n "${!eenv:-}" ]] && configured="true"
    printf '    %-14s ' "$ename"
    _status_channel_state "$ename" "$configured" "$now"
  done
}

cmd_status() {
  local mode="compact"
  case "${1:-}" in
    --full|-v) mode="full" ;;
  esac

  if [[ "$mode" == "full" ]]; then
    _status_full
  else
    _status_compact
  fi
}

_status_compact() {
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"

    local check_mark="${_TUI_GREEN}✓${_TUI_RESET}" dash="${_TUI_DIM}--${_TUI_RESET}"

    printf '\n%sshelldone %s%s (%s, %s)\n\n' "${_TUI_BOLD}" "$SHELLDONE_VERSION" "${_TUI_RESET}" "$_SHELLDONE_PLATFORM" "$(basename "${SHELL:-unknown}")"

    # Shell integration
    local zsh_status="$dash" bash_status="$dash"
    [[ -f "$HOME/.zshrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.zshrc" 2>/dev/null && zsh_status="$check_mark"
    [[ -f "$HOME/.bashrc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$HOME/.bashrc" 2>/dev/null && bash_status="$check_mark"
    printf '  Shell:      .zshrc %b  .bashrc %b\n' "$zsh_status" "$bash_status"

    # Desktop notification tool
    local desktop_tool="--"
    case "$_SHELLDONE_PLATFORM" in
      darwin) command -v terminal-notifier &>/dev/null && desktop_tool="terminal-notifier" || { command -v osascript &>/dev/null && desktop_tool="osascript"; } ;;
      linux)  command -v notify-send &>/dev/null && desktop_tool="notify-send" ;;
      wsl|windows) command -v powershell.exe &>/dev/null && desktop_tool="powershell.exe" ;;
    esac
    if [[ "$desktop_tool" != "--" ]]; then
      printf '  Desktop:    %s %b\n' "$desktop_tool" "$check_mark"
    else
      printf '  Desktop:    %b\n' "$dash"
    fi

    # Sound
    printf '  Sound:      %s / %s\n' "${SHELLDONE_SOUND_SUCCESS:-Glass}" "${SHELLDONE_SOUND_FAILURE:-Sosumi}"

    # Config file
    local config_file="${SHELLDONE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/shelldone/config}"
    if [[ -f "$config_file" ]]; then
      printf '  Config:     %s %b\n' "$config_file" "$check_mark"
    else
      printf '  Config:     not created\n'
    fi
    echo ""

    # Load state module
    local _state_lib="${SHELLDONE_LIB}/state.sh"
    if [[ -f "$_state_lib" ]]; then
      unset _SHELLDONE_STATE_LOADED
      source "$_state_lib"
    fi

    # Settings summary
    printf '  Auto-notify: %s (threshold: %ss, filter: %s)\n' \
      "${SHELLDONE_AUTO:-true}" "${SHELLDONE_THRESHOLD:-10}" "${SHELLDONE_NOTIFY_ON:-all}"
    printf '  Focus:       %s\n' "${SHELLDONE_FOCUS_DETECT:-true}"

    # Mute
    local mute_str="off"
    local mute_until
    if mute_until="$(_shelldone_state_read "mute_until" 2>/dev/null)"; then
      if [[ "$mute_until" == "0" ]]; then
        mute_str="on (indefinite)"
      else
        local now; now=$(date +%s)
        if (( mute_until > now )); then
          local remaining=$(( mute_until - now ))
          if (( remaining >= 3600 )); then
            mute_str="on ($(( remaining / 3600 ))h $(( (remaining % 3600) / 60 ))m left)"
          elif (( remaining >= 60 )); then
            mute_str="on ($(( remaining / 60 ))m left)"
          else
            mute_str="on (${remaining}s left)"
          fi
        fi
      fi
    fi
    printf '  Mute:        %s\n' "$mute_str"

    # Schedule
    local quiet_start quiet_end
    quiet_start="$(_shelldone_state_read "quiet_start" 2>/dev/null)" || quiet_start=""
    quiet_end="$(_shelldone_state_read "quiet_end" 2>/dev/null)" || quiet_end=""
    if [[ -n "$quiet_start" && -n "$quiet_end" ]]; then
      printf '  Schedule:    %s-%s\n' "$quiet_start" "$quiet_end"
    elif [[ -n "${SHELLDONE_QUIET_HOURS:-}" ]]; then
      printf '  Schedule:    %s\n' "$SHELLDONE_QUIET_HOURS"
    else
      printf '  Schedule:    none\n'
    fi
    echo ""

    # Channel status dashboard
    _status_channel_dashboard

    echo ""

    # AI hooks compact line
    printf '  AI Hooks:   '
    local ai_i
    for ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
      local ai_name="${_SHELLDONE_AI_NAMES[$ai_i]}"
      local ai_hook="${_SHELLDONE_AI_HOOKS[$ai_i]}"
      local ai_cmd="${_SHELLDONE_AI_CMDS[$ai_i]}"
      local ai_settings="${_SHELLDONE_AI_SETTINGS[$ai_i]}"
      local ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$ai_i]}"

      [[ -z "$ai_hook" ]] && continue

      local ai_detected=false
      if command -v "$ai_cmd" &>/dev/null || [[ -n "$ai_config_dir" && -d "$ai_config_dir" ]]; then
        ai_detected=true
      fi

      if ! $ai_detected; then
        printf ' %s %b' "$ai_name" "$dash"
        continue
      fi

      local hook_file="${SHELLDONE_HOOKS}/${ai_hook}"
      local hook_installed=false
      if [[ "$ai_name" == "copilot" ]]; then
        local copilot_hook="$HOME/.github/hooks/shelldone-session-end.json"
        [[ -f "$copilot_hook" ]] && grep -q "copilot-done" "$copilot_hook" 2>/dev/null && hook_installed=true
      elif [[ -n "$ai_settings" && -f "$ai_settings" ]]; then
        local hook_basename; hook_basename=$(basename "$hook_file")
        grep -q "${hook_basename%.sh}" "$ai_settings" 2>/dev/null && hook_installed=true
      fi

      if $hook_installed; then
        printf ' %s %b' "$ai_name" "$check_mark"
      else
        printf ' %s %b' "$ai_name" "$dash"
      fi
    done
    echo ""

    printf '\n  Tip: Run %sshelldone doctor%s to diagnose issues\n\n' "${_TUI_BOLD}" "${_TUI_RESET}"
  )
}

_status_full() {
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"

    echo "shelldone $SHELLDONE_VERSION"

    # Install path
    local bin_path
    bin_path="$(cd "$(dirname "$0")" && pwd)/shelldone"
    echo "  Install path:   $bin_path"
    echo "  Platform:       $_SHELLDONE_PLATFORM"
    echo "  Shell:          $(basename "${SHELL:-unknown}")"
    echo ""

    # Shell integration
    echo "Shell integration:"
    local rc check_mark="✓" cross_mark="-"
    for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
      local name
      name="$(basename "$rc")"
      if [[ -f "$rc" ]] && grep -qF "shelldone" "$rc" 2>/dev/null; then
        printf '  ~/%s:%*s%s installed\n' "$name" $((14 - ${#name})) "" "$check_mark"
      else
        printf '  ~/%s:%*s%s not found\n' "$name" $((14 - ${#name})) "" "$cross_mark"
      fi
    done
    echo ""

    # Notification tools
    echo "Notification tools:"
    case "$_SHELLDONE_PLATFORM" in
      darwin)
        for tool in terminal-notifier osascript afplay say; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
      linux)
        for tool in notify-send paplay aplay espeak; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
      wsl|windows)
        for tool in powershell.exe wsl-notify-send; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
    esac
    echo ""

    # Config
    echo "Config:"
    echo "  SHELLDONE_ENABLED=$SHELLDONE_ENABLED"
    echo "  SHELLDONE_AUTO=${SHELLDONE_AUTO:-true}"
    echo "  SHELLDONE_THRESHOLD=${SHELLDONE_THRESHOLD:-10}"
    echo "  SHELLDONE_SOUND_SUCCESS=$SHELLDONE_SOUND_SUCCESS"
    echo "  SHELLDONE_SOUND_FAILURE=$SHELLDONE_SOUND_FAILURE"
    echo "  SHELLDONE_VOICE=${SHELLDONE_VOICE:-<off>}"
    echo "  SHELLDONE_DEBUG=${SHELLDONE_DEBUG:-<off>}"
    echo "  SHELLDONE_SOUND_TIMEOUT=${SHELLDONE_SOUND_TIMEOUT:-10}"
    echo "  SHELLDONE_FOCUS_DETECT=${SHELLDONE_FOCUS_DETECT:-true}"
    echo "  SHELLDONE_NOTIFY_ON=${SHELLDONE_NOTIFY_ON:-all}"
    echo "  SHELLDONE_ACTIVATE=${SHELLDONE_ACTIVATE:-<auto-detect>}"
    echo "  SHELLDONE_EXCLUDE=${SHELLDONE_EXCLUDE:-vim nvim vi nano ...}"
    echo ""

    # Config file
    echo "Config file:"
    local config_file="${SHELLDONE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/shelldone/config}"
    if [[ -f "$config_file" ]]; then
      printf '  %s %s\n' "$check_mark" "$config_file"
    else
      printf '  %s not found (%s)\n' "$cross_mark" "$config_file"
    fi
    echo ""

    # History
    echo "History:"
    local log_file="${SHELLDONE_HISTORY_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/shelldone}/history.log"
    if [[ -f "$log_file" ]]; then
      local count
      count=$(wc -l < "$log_file" | tr -d ' ')
      printf '  %s %s (%s entries)\n' "$check_mark" "$log_file" "$count"
    else
      printf '  %s %s (not yet created)\n' "$cross_mark" "$log_file"
    fi
    echo ""

    # AI CLI hooks
    echo "AI CLI hooks:"
    local ai_i
    for ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
      local ai_name="${_SHELLDONE_AI_NAMES[$ai_i]}"
      local ai_label="${_SHELLDONE_AI_LABELS[$ai_i]}"
      local ai_hook="${_SHELLDONE_AI_HOOKS[$ai_i]}"
      local ai_cmd="${_SHELLDONE_AI_CMDS[$ai_i]}"
      local ai_settings="${_SHELLDONE_AI_SETTINGS[$ai_i]}"
      local ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$ai_i]}"

      # Aider: no hooks
      if [[ -z "$ai_hook" ]]; then
        if command -v "$ai_cmd" &>/dev/null; then
          printf '  %-14s %s detected (use: alert aider <prompt>)\n' "${ai_label}:" "$check_mark"
        else
          printf '  %-14s %s not detected\n' "${ai_label}:" "$cross_mark"
        fi
        continue
      fi

      # Check if AI CLI is present
      if ! command -v "$ai_cmd" &>/dev/null && [[ -z "$ai_config_dir" || ! -d "$ai_config_dir" ]]; then
        printf '  %-14s %s not detected\n' "${ai_label}:" "$cross_mark"
        continue
      fi

      # Check hook installation
      local hook_file="${SHELLDONE_HOOKS}/${ai_hook}"
      local hook_installed=false

      # Copilot uses a file-based approach
      if [[ "$ai_name" == "copilot" ]]; then
        local copilot_hook="$HOME/.github/hooks/shelldone-session-end.json"
        if [[ -f "$copilot_hook" ]] && grep -q "copilot-done" "$copilot_hook" 2>/dev/null; then
          hook_installed=true
        fi
      elif [[ -n "$ai_settings" && -f "$ai_settings" ]]; then
        local hook_basename
        hook_basename=$(basename "$hook_file")
        if grep -q "${hook_basename%.sh}" "$ai_settings" 2>/dev/null; then
          hook_installed=true
        fi
      fi

      # Check toggle state
      local ai_toggle_val
      ai_toggle_val="$(_shelldone_state_read "$ai_name" 2>/dev/null)" || ai_toggle_val=""

      if $hook_installed; then
        if [[ "$ai_toggle_val" == "off" ]]; then
          printf '  %-14s %s installed (toggled off)\n' "${ai_label}:" "$check_mark"
        else
          printf '  %-14s %s installed\n' "${ai_label}:" "$check_mark"
        fi
      else
        printf '  %-14s %s not installed (run: shelldone setup %s-hook)\n' "${ai_label}:" "$cross_mark" "$ai_name"
      fi
    done
    echo ""

    # External notifications
    echo "External notifications:"
    local has_external=""
    [[ -n "${SHELLDONE_SLACK_WEBHOOK:-}" ]]   && has_external+="slack "
    [[ -n "${SHELLDONE_DISCORD_WEBHOOK:-}" ]] && has_external+="discord "
    [[ -n "${SHELLDONE_TELEGRAM_TOKEN:-}" ]]  && has_external+="telegram "
    [[ -n "${SHELLDONE_EMAIL_TO:-}" ]]        && has_external+="email "
    [[ -n "${SHELLDONE_WHATSAPP_TOKEN:-}" ]]  && has_external+="whatsapp "
    [[ -n "${SHELLDONE_WEBHOOK_URL:-}" ]]     && has_external+="webhook "
    if [[ -n "$has_external" ]]; then
      printf '  Active channels: %s\n' "$has_external"
      local transport="none"
      if command -v curl &>/dev/null; then transport="curl"
      elif command -v wget &>/dev/null; then transport="wget"
      else transport="/dev/tcp (HTTP only)"
      fi
      printf '  HTTP transport:  %s\n' "$transport"
      printf '  Rate limit:      %ss\n' "${SHELLDONE_RATE_LIMIT:-10}"
    else
      printf '  - no channels configured (run "shelldone webhook status" for details)\n'
    fi
    echo ""

    # Notification control (mute, toggle, schedule)
    echo "Notification control:"

    # Load state module
    local _state_lib="${SHELLDONE_LIB}/state.sh"
    if [[ -f "$_state_lib" ]]; then
      unset _SHELLDONE_STATE_LOADED
      source "$_state_lib"
    fi

    # Mute status
    local mute_until
    if mute_until="$(_shelldone_state_read "mute_until" 2>/dev/null)"; then
      if [[ "$mute_until" == "0" ]]; then
        printf '  Mute:            muted indefinitely\n'
      else
        local now
        now=$(date +%s)
        if (( mute_until > now )); then
          local remaining=$(( mute_until - now ))
          local rem_str
          if (( remaining >= 3600 )); then
            rem_str="$(( remaining / 3600 ))h $(( (remaining % 3600) / 60 ))m"
          elif (( remaining >= 60 )); then
            rem_str="$(( remaining / 60 ))m"
          else
            rem_str="${remaining}s"
          fi
          printf '  Mute:            muted (%s remaining)\n' "$rem_str"
        else
          printf '  Mute:            not muted\n'
        fi
      fi
    else
      printf '  Mute:            not muted\n'
    fi

    # Toggle states
    local layer val indicator
    for layer in desktop sound voice; do
      val="$(_shelldone_state_read "$layer" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-17s off  (toggled off)\n' "${layer}:"
      else
        printf '  %-17s on\n' "${layer}:"
      fi
    done

    # External channel toggles
    local -a ext_channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
    local -a ext_envvars=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
    local i
    for i in "${!ext_channels[@]}"; do
      layer="${ext_channels[$i]}"
      local envvar="${ext_envvars[$i]}"
      val="$(_shelldone_state_read "$layer" 2>/dev/null)" || val=""
      if [[ -z "${!envvar:-}" ]]; then
        printf '  %-17s -    (not configured)\n' "${layer}:"
      elif [[ "$val" == "off" ]]; then
        printf '  %-17s off  (toggled off)\n' "${layer}:"
      else
        printf '  %-17s on\n' "${layer}:"
      fi
    done

    # Schedule
    local quiet_start quiet_end
    quiet_start="$(_shelldone_state_read "quiet_start" 2>/dev/null)" || quiet_start=""
    quiet_end="$(_shelldone_state_read "quiet_end" 2>/dev/null)" || quiet_end=""
    if [[ -n "$quiet_start" && -n "$quiet_end" ]]; then
      printf '  Schedule:        %s-%s\n' "$quiet_start" "$quiet_end"
    elif [[ -n "${SHELLDONE_QUIET_HOURS:-}" ]]; then
      printf '  Schedule:        %s (env)\n' "$SHELLDONE_QUIET_HOURS"
    else
      printf '  Schedule:        none\n'
    fi
  )
}

cmd_test_notify() {
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"
    # Bypass focus detection - this is an explicit test
    SHELLDONE_FOCUS_DETECT=false
    echo "Sending test notification..."
    if _shelldone_notify "shelldone Test" "If you see this, notifications are working!" 0; then
      printf '\033[1;32m[shelldone]\033[0m Notification sent! Check your notification center.\n'
    else
      printf '\033[1;31m[shelldone]\033[0m Notification may have failed. Run "shelldone status" to diagnose.\n'
    fi
  )
}

cmd_sounds() {
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"
    printf 'Available sounds for %s:\n\n' "$_SHELLDONE_PLATFORM"
    case "$_SHELLDONE_PLATFORM" in
      darwin)
        for f in /System/Library/Sounds/*.aiff; do
          [[ -f "$f" ]] || continue
          local name
          name="$(basename "$f" .aiff)"
          local marker=""
          [[ "$name" == "$SHELLDONE_SOUND_SUCCESS" ]] && marker=" (success)"
          [[ "$name" == "$SHELLDONE_SOUND_FAILURE" ]] && marker=" (failure)"
          printf '  %s%s\n' "$name" "$marker"
        done
        ;;
      linux)
        for f in /usr/share/sounds/freedesktop/stereo/*.oga; do
          [[ -f "$f" ]] || continue
          local name
          name="$(basename "$f" .oga)"
          local marker=""
          [[ "$name" == "$SHELLDONE_SOUND_SUCCESS" ]] && marker=" (success)"
          [[ "$name" == "$SHELLDONE_SOUND_FAILURE" ]] && marker=" (failure)"
          printf '  %s%s\n' "$name" "$marker"
        done
        ;;
      wsl|windows)
        printf '  Asterisk, Hand, Exclamation, Question\n'
        ;;
      *)
        echo "  No system sounds directory known for this platform."
        ;;
    esac
    printf '\nCurrent: success=%s, failure=%s\n' "$SHELLDONE_SOUND_SUCCESS" "$SHELLDONE_SOUND_FAILURE"
    printf 'Set via: export SHELLDONE_SOUND_SUCCESS=Ping\n'
    printf 'Tip: Use a file path for custom sounds (e.g., /path/to/sound.wav)\n'
  )
}

cmd_exclude() {
  local action="${1:-list}"
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"
    local current="${SHELLDONE_EXCLUDE:-vim nvim vi nano less more man top htop ssh tmux screen fg bg watch}"

    case "$action" in
      list)
        echo "Current exclusion list:"
        local item
        for item in $current; do
          printf '  %s\n' "$item"
        done
        echo ""
        printf 'Supports glob patterns (e.g., npm* matches npm, npx, etc.)\n'
        ;;
      add)
        local pattern="${2:-}"
        if [[ -z "$pattern" ]]; then
          echo >&2 "Usage: shelldone exclude add <pattern>"
          exit 1
        fi
        local new_list="${current} ${pattern}"
        _config_set_value "SHELLDONE_EXCLUDE" "$new_list"
        _tui_ok "Added '${pattern}' to exclusion list"
        printf '  Current: %s\n' "$new_list"
        printf '  Active in new shell sessions\n'
        ;;
      remove)
        local pattern="${2:-}"
        if [[ -z "$pattern" ]]; then
          echo >&2 "Usage: shelldone exclude remove <pattern>"
          exit 1
        fi
        local new_list=""
        local item
        for item in $current; do
          if [[ "$item" != "$pattern" ]]; then
            new_list="${new_list:+$new_list }$item"
          fi
        done
        _config_set_value "SHELLDONE_EXCLUDE" "$new_list"
        _tui_ok "Removed '${pattern}' from exclusion list"
        printf '  Current: %s\n' "$new_list"
        printf '  Active in new shell sessions\n'
        ;;
      *)
        echo >&2 "Usage: shelldone exclude [list|add <pattern>|remove <pattern>]"
        exit 1
        ;;
    esac
  )
}

cmd_webhook() {
  local action="${1:-status}"
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"

    case "$action" in
      status)
        echo "External notifications:"
        printf '  %sTip: try "shelldone channel" for guided setup%s\n\n' "${_TUI_DIM}" "${_TUI_RESET}"

        # Transport
        local transport="none"
        if command -v curl &>/dev/null; then
          transport="curl ($(command -v curl))"
        elif command -v wget &>/dev/null; then
          transport="wget ($(command -v wget))"
        else
          transport="/dev/tcp (HTTP only, no HTTPS)"
        fi
        echo "  HTTP transport: $transport"
        echo "  Rate limit:     ${SHELLDONE_RATE_LIMIT:-10}s"
        echo "  Timeout:        ${SHELLDONE_WEBHOOK_TIMEOUT:-5}s"
        echo ""

        # Channel status
        local check_mark="✓" cross_mark="-"
        echo "  Channels:"
        if [[ -n "${SHELLDONE_SLACK_WEBHOOK:-}" ]]; then
          printf '    %-12s%s configured\n' "Slack:" "$check_mark"
        else
          printf '    %-12s%s not configured (set SHELLDONE_SLACK_WEBHOOK)\n' "Slack:" "$cross_mark"
        fi
        if [[ -n "${SHELLDONE_DISCORD_WEBHOOK:-}" ]]; then
          printf '    %-12s%s configured\n' "Discord:" "$check_mark"
        else
          printf '    %-12s%s not configured (set SHELLDONE_DISCORD_WEBHOOK)\n' "Discord:" "$cross_mark"
        fi
        if [[ -n "${SHELLDONE_TELEGRAM_TOKEN:-}" ]]; then
          if [[ -n "${SHELLDONE_TELEGRAM_CHAT_ID:-}" ]]; then
            printf '    %-12s%s configured\n' "Telegram:" "$check_mark"
          else
            printf '    %-12s%s token set but missing SHELLDONE_TELEGRAM_CHAT_ID\n' "Telegram:" "$cross_mark"
          fi
        else
          printf '    %-12s%s not configured (set SHELLDONE_TELEGRAM_TOKEN)\n' "Telegram:" "$cross_mark"
        fi
        if [[ -n "${SHELLDONE_EMAIL_TO:-}" ]]; then
          local mailer="none"
          if command -v sendmail &>/dev/null; then mailer="sendmail"
          elif command -v mail &>/dev/null; then mailer="mail"
          fi
          printf '    %-12s%s configured (via %s)\n' "Email:" "$check_mark" "$mailer"
        else
          printf '    %-12s%s not configured (set SHELLDONE_EMAIL_TO)\n' "Email:" "$cross_mark"
        fi
        if [[ -n "${SHELLDONE_WHATSAPP_TOKEN:-}" ]]; then
          printf '    %-12s%s configured\n' "WhatsApp:" "$check_mark"
        else
          printf '    %-12s%s not configured (set SHELLDONE_WHATSAPP_TOKEN)\n' "WhatsApp:" "$cross_mark"
        fi
        if [[ -n "${SHELLDONE_WEBHOOK_URL:-}" ]]; then
          printf '    %-12s%s configured\n' "Webhook:" "$check_mark"
        else
          printf '    %-12s%s not configured (set SHELLDONE_WEBHOOK_URL)\n' "Webhook:" "$cross_mark"
        fi
        ;;
      test)
        local channel="${2:-}"
        if [[ -z "$channel" ]]; then
          echo >&2 "Usage: shelldone webhook test <channel>"
          echo >&2 "Channels: slack discord telegram email whatsapp webhook"
          exit 1
        fi

        # Load external module
        _shelldone_load_external

        if ! declare -f _shelldone_validate_channel &>/dev/null; then
          echo >&2 "shelldone: external notification module not loaded"
          exit 1
        fi

        # Validate ALL required vars upfront
        local validation_error
        if ! validation_error=$(_shelldone_validate_channel "$channel" 2>&1); then
          printf '\033[1;31m[shelldone]\033[0m %s: %s\n' "$channel" "$validation_error" >&2
          exit 1
        fi

        local send_fn="_shelldone_external_${channel}"
        if ! declare -f "$send_fn" &>/dev/null; then
          echo >&2 "shelldone: unknown channel '$channel'"
          exit 1
        fi

        echo "Sending test to ${channel}..."
        _SHELLDONE_SKIP_RATE_LIMIT=true

        # Set metadata for enriched Slack Block Kit preview
        export _SHELLDONE_META_CMD="shelldone webhook test ${channel}"
        export _SHELLDONE_META_DURATION="0s"
        export _SHELLDONE_META_SOURCE="shell"

        if "$send_fn" "shelldone Test" "If you receive this, your ${channel} integration is working!" 0; then
          printf '\033[1;32m[shelldone]\033[0m Test sent successfully!'
          [[ -n "${_SHELLDONE_LAST_HTTP_STATUS:-}" && "${_SHELLDONE_LAST_HTTP_STATUS:-}" != "unknown" ]] && printf ' (HTTP %s)' "$_SHELLDONE_LAST_HTTP_STATUS"
          printf '\n'
        else
          printf '\033[1;31m[shelldone]\033[0m Test FAILED.'
          [[ -n "${_SHELLDONE_LAST_HTTP_STATUS:-}" && "${_SHELLDONE_LAST_HTTP_STATUS:-}" != "unknown" ]] && printf ' (HTTP %s)' "$_SHELLDONE_LAST_HTTP_STATUS"
          printf '\n'
          if [[ "${_SHELLDONE_LAST_HTTP_STATUS:-}" == "000" ]]; then
            printf '\033[1;33m[shelldone]\033[0m HTTP 000 = connection failed (DNS or network error).\n'
            [[ -n "${_SHELLDONE_LAST_CURL_ERROR:-}" ]] && printf '\033[1;33m[shelldone]\033[0m curl: %s\n' "$_SHELLDONE_LAST_CURL_ERROR"
            printf '\033[1;33m[shelldone]\033[0m Tip: check for invisible characters in the URL (re-type manually instead of pasting).\n'
          fi
          printf '\033[1;33m[shelldone]\033[0m Run with SHELLDONE_EXTERNAL_DEBUG=true for details.\n'
          exit 1
        fi
        ;;
      *)
        echo >&2 "Usage: shelldone webhook [status|test <channel>]"
        exit 1
        ;;
    esac
  )
}

cmd_history() {
  local action="${1:-show}"
  local log_dir="${SHELLDONE_HISTORY_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/shelldone}"
  local log_file="${log_dir}/history.log"

  case "$action" in
    show|"")
      if [[ ! -f "$log_file" ]]; then
        echo "No notification history found."
        echo "  Log file: $log_file"
        return 0
      fi
      local count="${2:-20}"
      echo "Recent notifications (last $count):"
      echo ""
      printf '%-19s  %-4s  %-30s  %s\n' "TIMESTAMP" "EXIT" "TITLE" "CHANNELS"
      printf '%-19s  %-4s  %-30s  %s\n' "-------------------" "----" "------------------------------" "--------"
      tail -n "$count" "$log_file" | while IFS=$'\t' read -r ts title msg exit_code channels; do
        printf '%-19s  %-4s  %-30s  %s\n' "$ts" "$exit_code" "$title" "$channels"
      done
      echo ""
      echo "Log file: $log_file"
      ;;
    --clear)
      if [[ -f "$log_file" ]]; then
        local entry_count
        entry_count=$(wc -l < "$log_file" | tr -d ' ')
        if _tui_is_interactive; then
          if ! _tui_confirm "Clear all notification history (${entry_count} entries)?"; then
            echo "Cancelled."
            return 0
          fi
        fi
        rm -f "$log_file"
        echo "History cleared."
      else
        echo "No history file to clear."
      fi
      ;;
    --path)
      echo "$log_file"
      ;;
    *)
      echo >&2 "Usage: shelldone history [show [N]|--clear|--path]"
      exit 1
      ;;
  esac
}

cmd_config() {
  local action="${1:-show}"
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/shelldone"
  local config_file="${SHELLDONE_CONFIG:-${config_dir}/config}"

  case "$action" in
    show|"")
      echo "Config file: $config_file"
      if [[ -f "$config_file" ]]; then
        echo "Status: loaded"
        echo ""
        echo "Contents:"
        cat "$config_file"
      else
        echo "Status: not found"
        echo ""
        echo "To create a config file:"
        echo "  mkdir -p \"$config_dir\""
        echo "  shelldone config init > \"$config_file\""
      fi
      ;;
    init)
      cat <<'CONFIGEOF'
# shelldone configuration
# Sourced on startup. Env vars set before "shelldone init" override these.
# Use :="${VAR:=value}" so explicit env vars take precedence.

# Master switch
: "${SHELLDONE_ENABLED:=true}"

# Auto-notify for long commands
: "${SHELLDONE_AUTO:=true}"
: "${SHELLDONE_THRESHOLD:=10}"

# Notification filter: all, failure, success
: "${SHELLDONE_NOTIFY_ON:=all}"

# Sound names or file paths
# : "${SHELLDONE_SOUND_SUCCESS:=Glass}"
# : "${SHELLDONE_SOUND_FAILURE:=Sosumi}"

# TTS announcements
# : "${SHELLDONE_VOICE:=true}"

# Focus detection
: "${SHELLDONE_FOCUS_DETECT:=true}"

# Notification history
: "${SHELLDONE_HISTORY:=true}"

# Commands to exclude (space-separated, supports globs)
# : "${SHELLDONE_EXCLUDE:=vim nvim vi nano less more man top htop ssh tmux screen fg bg alert-bg watch}"

# macOS: app to switch to when clicking notification (auto-detected from $TERM_PROGRAM)
# Requires terminal-notifier: brew install terminal-notifier
# Common values: com.microsoft.VSCode, com.apple.Terminal, com.googlecode.iterm2
# : "${SHELLDONE_ACTIVATE:=}"

# Quiet hours (HH:MM-HH:MM, crosses midnight OK)
# : "${SHELLDONE_QUIET_HOURS:=22:00-08:00}"

# External channels (uncomment and fill in):
# export SHELLDONE_SLACK_WEBHOOK="https://hooks.slack.com/services/..."
# export SHELLDONE_DISCORD_WEBHOOK="https://discord.com/api/webhooks/..."
# export SHELLDONE_TELEGRAM_TOKEN="..."
# export SHELLDONE_TELEGRAM_CHAT_ID="..."
# export SHELLDONE_EMAIL_TO="you@example.com"
# export SHELLDONE_WEBHOOK_URL="https://your-endpoint.com/hook"
CONFIGEOF
      ;;
    edit)
      if [[ ! -f "$config_file" ]]; then
        if _tui_is_interactive; then
          if _tui_confirm "Config file doesn't exist. Create it?"; then
            mkdir -p "$config_dir"
            cmd_config init > "$config_file"
            _tui_ok "Created $config_file"
          else
            return 0
          fi
        else
          echo >&2 "Config file does not exist. Create it first:"
          echo >&2 "  mkdir -p \"$config_dir\" && shelldone config init > \"$config_file\""
          exit 1
        fi
      fi
      "${EDITOR:-${VISUAL:-vi}}" "$config_file"
      ;;
    path)
      echo "$config_file"
      ;;
    set)
      local key="${2:-}" value="${3:-}"
      if [[ -z "$key" ]] || [[ -z "$value" ]]; then
        echo >&2 "Usage: shelldone config set KEY VALUE"
        echo >&2 "Example: shelldone config set SHELLDONE_THRESHOLD 30"
        exit 1
      fi
      # Validate key
      local valid=false k
      for k in $_SHELLDONE_VALID_KEYS; do
        [[ "$k" == "$key" ]] && valid=true && break
      done
      if ! $valid; then
        echo >&2 "shelldone: unknown config key '$key'"
        echo >&2 "Valid keys: $_SHELLDONE_VALID_KEYS" | fold -s -w 80
        exit 1
      fi
      _config_set_value "$key" "$value"
      _tui_ok "${key}=${value} (saved to config)"
      ;;
    get)
      local key="${2:-}"
      if [[ -z "$key" ]]; then
        echo >&2 "Usage: shelldone config get KEY"
        exit 1
      fi
      printf '%s = %s\n' "$key" "$(_config_get_value "$key")"
      ;;
    list)
      (
        unset _SHELLDONE_LOADED
        source "${SHELLDONE_LIB}/shelldone.sh"
        printf '%s%-30s %s%s\n' "${_TUI_BOLD}" "KEY" "VALUE" "${_TUI_RESET}"
        printf '%-30s %s\n' "------------------------------" "-----"
        local k
        for k in $_SHELLDONE_VALID_KEYS; do
          printf '%-30s %s\n' "$k" "$(_config_get_value "$k")"
        done
      )
      ;;
    *)
      echo >&2 "Usage: shelldone config [show|init|edit|path|set KEY VALUE|get KEY|list]"
      exit 1
      ;;
  esac
}

_load_state_module() {
  if [[ -z "${_SHELLDONE_STATE_LOADED:-}" ]]; then
    local _state_lib="${SHELLDONE_LIB}/state.sh"
    if [[ -f "$_state_lib" ]]; then
      source "$_state_lib"
    else
      echo >&2 "shelldone: state module not found"
      exit 1
    fi
  fi
}

_mute_valid_channels="desktop sound voice slack discord telegram email whatsapp webhook"

_mute_format_expiry() {
  local ts="$1"
  local expiry_str
  if expiry_str=$(date -d "@${ts}" '+%H:%M:%S' 2>/dev/null); then
    true
  elif expiry_str=$(date -r "${ts}" '+%H:%M:%S' 2>/dev/null); then
    true
  else
    expiry_str="epoch ${ts}"
  fi
  printf '%s' "$expiry_str"
}

_mute_apply() {
  local target="$1" duration_str="$2"
  local mute_val="0"

  if [[ -n "$duration_str" ]]; then
    local seconds
    if ! seconds="$(_shelldone_parse_duration "$duration_str")"; then
      echo >&2 "Usage: shelldone mute [channel] [duration]  (e.g., slack 2h)"
      exit 1
    fi
    mute_val=$(( $(date +%s) + seconds ))
  fi

  if [[ -z "$target" ]]; then
    # Global mute
    _shelldone_state_write "mute_until" "$mute_val"
    if [[ "$mute_val" == "0" ]]; then
      printf '\033[1;32m[shelldone]\033[0m Muted indefinitely. Run "shelldone unmute" to resume.\n'
    else
      printf '\033[1;32m[shelldone]\033[0m Muted for %s (until %s)\n' "$duration_str" "$(_mute_format_expiry "$mute_val")"
    fi
  else
    # Per-channel mute
    _shelldone_state_write "mute_${target}_until" "$mute_val"
    if [[ "$mute_val" == "0" ]]; then
      printf '\033[1;32m[shelldone]\033[0m %s muted indefinitely.\n' "$target"
    else
      printf '\033[1;32m[shelldone]\033[0m %s muted for %s (until %s)\n' "$target" "$duration_str" "$(_mute_format_expiry "$mute_val")"
    fi
  fi
}

_mute_validate_channel() {
  local channel="$1" ch
  for ch in $_mute_valid_channels; do
    [[ "$ch" == "$channel" ]] && return 0
  done
  echo >&2 "shelldone: unknown channel '$channel'"
  echo >&2 "Valid channels: $_mute_valid_channels"
  exit 1
}

_mute_interactive() {
  _tui_select "What would you like to mute?" "All channels" "Specific channel"
  if [[ "$_TUI_SELECTED" == "All channels" ]]; then
    local dur
    dur="$(_tui_prompt "Duration? (e.g., 30m, 2h, or leave empty for indefinite)")"
    _mute_apply "" "$dur"
  else
    _tui_select "Select channel to mute:" $_mute_valid_channels
    local selected_channel="$_TUI_SELECTED"
    local dur
    dur="$(_tui_prompt "Duration? (e.g., 30m, 2h, or leave empty for indefinite)")"
    _mute_apply "$selected_channel" "$dur"
  fi
}

cmd_mute() {
  _load_state_module
  local arg1="${1:-}" arg2="${2:-}"

  if [[ -z "$arg1" ]]; then
    # No args: interactive if TTY, global indefinite if not
    if _tui_is_interactive; then
      _mute_interactive
    else
      _mute_apply "" ""
    fi
    return 0
  fi

  # One arg: duration (global) or channel name (per-channel indefinite)?
  if [[ -z "$arg2" ]]; then
    if _shelldone_parse_duration "$arg1" >/dev/null 2>&1; then
      _mute_apply "" "$arg1"
    else
      _mute_validate_channel "$arg1"
      _mute_apply "$arg1" ""
    fi
    return 0
  fi

  # Two args: channel + duration
  _mute_validate_channel "$arg1"
  _mute_apply "$arg1" "$arg2"
}

cmd_unmute() {
  _load_state_module
  local channel="${1:-}"

  if [[ -z "$channel" ]]; then
    _shelldone_unmute_all
    printf '\033[1;32m[shelldone]\033[0m Unmuted. All notifications resumed.\n'
  else
    _mute_validate_channel "$channel"
    _shelldone_unmute_channel "$channel"
    printf '\033[1;32m[shelldone]\033[0m %s unmuted.\n' "$channel"
  fi
}

cmd_toggle() {
  _load_state_module
  local layer="${1:-}" explicit="${2:-}"

  local -a valid_layers=(sound desktop voice slack discord telegram email whatsapp webhook claude codex gemini copilot cursor)

  if [[ -z "$layer" ]]; then
    # Show all toggle states
    echo "Toggle states:"
    local l val
    for l in desktop sound voice; do
      val="$(_shelldone_state_read "$l" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${l}:"
      else
        printf '  %-12s on\n' "${l}:"
      fi
    done

    # External channels with configured indicator
    local -a ext_channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
    local -a ext_envvars=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
    local i
    for i in "${!ext_channels[@]}"; do
      l="${ext_channels[$i]}"
      local envvar="${ext_envvars[$i]}"
      val="$(_shelldone_state_read "$l" 2>/dev/null)" || val=""
      if [[ -z "${!envvar:-}" ]]; then
        printf '  %-12s -    (not configured)\n' "${l}:"
      elif [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${l}:"
      else
        printf '  %-12s on   (configured)\n' "${l}:"
      fi
    done

    # AI CLI hooks
    echo ""
    echo "AI CLI hooks:"
    local ai_i
    for ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
      local ai_name="${_SHELLDONE_AI_NAMES[$ai_i]}"
      local ai_hook="${_SHELLDONE_AI_HOOKS[$ai_i]}"
      local ai_cmd="${_SHELLDONE_AI_CMDS[$ai_i]}"
      local ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$ai_i]}"

      # Skip Aider (no hooks, no toggle)
      [[ -z "$ai_hook" ]] && continue

      # Check if detected
      if ! command -v "$ai_cmd" &>/dev/null && [[ -z "$ai_config_dir" || ! -d "$ai_config_dir" ]]; then
        printf '  %-12s -    (not detected)\n' "${ai_name}:"
        continue
      fi

      val="$(_shelldone_state_read "$ai_name" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${ai_name}:"
      else
        printf '  %-12s on\n' "${ai_name}:"
      fi
    done
    return 0
  fi

  # Handle "external" group
  if [[ "$layer" == "external" ]]; then
    local target="${explicit:-}"
    if [[ -z "$target" ]]; then
      # Flip: if any external is on, turn all off; otherwise all on
      local any_on=false
      for l in slack discord telegram email whatsapp webhook; do
        val="$(_shelldone_state_read "$l" 2>/dev/null)" || val=""
        [[ "$val" != "off" ]] && any_on=true && break
      done
      if $any_on; then target="off"; else target="on"; fi
    fi
    for l in slack discord telegram email whatsapp webhook; do
      if [[ "$target" == "on" ]]; then
        _shelldone_state_delete "$l"
      else
        _shelldone_state_write "$l" "off"
      fi
    done
    printf '\033[1;32m[shelldone]\033[0m All external channels: %s\n' "$target"
    return 0
  fi

  # Validate layer name
  local found=false
  for l in "${valid_layers[@]}"; do
    [[ "$l" == "$layer" ]] && found=true && break
  done
  if ! $found; then
    echo >&2 "shelldone: unknown layer '$layer'"
    echo >&2 "Valid layers: ${valid_layers[*]} external"
    exit 1
  fi

  if [[ -n "$explicit" ]]; then
    # Explicit on/off
    case "$explicit" in
      on)
        _shelldone_state_delete "$layer"
        printf '\033[1;32m[shelldone]\033[0m %s: on\n' "$layer"
        ;;
      off)
        _shelldone_state_write "$layer" "off"
        printf '\033[1;32m[shelldone]\033[0m %s: off\n' "$layer"
        ;;
      *)
        echo >&2 "Usage: shelldone toggle <layer> [on|off]"
        exit 1
        ;;
    esac
  else
    # Flip current state
    local current
    current="$(_shelldone_state_read "$layer" 2>/dev/null)" || current=""
    if [[ "$current" == "off" ]]; then
      _shelldone_state_delete "$layer"
      printf '\033[1;32m[shelldone]\033[0m %s: on\n' "$layer"
    else
      _shelldone_state_write "$layer" "off"
      printf '\033[1;32m[shelldone]\033[0m %s: off\n' "$layer"
    fi
  fi
}

cmd_schedule() {
  _load_state_module
  local input="${1:-}"

  if [[ -z "$input" ]]; then
    # Show current schedule
    local quiet_start quiet_end
    quiet_start="$(_shelldone_state_read "quiet_start" 2>/dev/null)" || quiet_start=""
    quiet_end="$(_shelldone_state_read "quiet_end" 2>/dev/null)" || quiet_end=""
    if [[ -n "$quiet_start" && -n "$quiet_end" ]]; then
      printf 'Quiet hours: %s-%s\n' "$quiet_start" "$quiet_end"
    elif [[ -n "${SHELLDONE_QUIET_HOURS:-}" ]]; then
      printf 'Quiet hours: %s (from env)\n' "$SHELLDONE_QUIET_HOURS"
    else
      echo "No schedule set."
    fi
    return 0
  fi

  if [[ "$input" == "off" ]]; then
    _shelldone_state_delete "quiet_start"
    _shelldone_state_delete "quiet_end"
    printf '\033[1;32m[shelldone]\033[0m Schedule cleared.\n'
    return 0
  fi

  # Validate HH:MM-HH:MM format
  if [[ ! "$input" =~ ^([0-9]{2}:[0-9]{2})-([0-9]{2}:[0-9]{2})$ ]]; then
    echo >&2 "Usage: shelldone schedule [HH:MM-HH:MM|off]"
    echo >&2 "Example: shelldone schedule 22:00-08:00"
    exit 1
  fi

  local start="${BASH_REMATCH[1]}" end="${BASH_REMATCH[2]}"

  # Validate hours and minutes
  local start_h="${start%%:*}" start_m="${start##*:}"
  local end_h="${end%%:*}" end_m="${end##*:}"
  if (( 10#$start_h > 23 || 10#$start_m > 59 || 10#$end_h > 23 || 10#$end_m > 59 )); then
    echo >&2 "shelldone: invalid time in schedule"
    exit 1
  fi

  _shelldone_state_write "quiet_start" "$start"
  _shelldone_state_write "quiet_end" "$end"
  printf '\033[1;32m[shelldone]\033[0m Quiet hours set: %s-%s\n' "$start" "$end"
}

cmd_help() {
  cat <<'HELP'
shelldone - Terminal process completion notifier

Getting Started:
  shelldone setup                Interactive setup wizard
  shelldone setup --quick        Non-interactive, sensible defaults
  shelldone doctor               Check configuration for issues
  shelldone test-notify          Send a test notification
  shelldone status               Quick status overview
  shelldone status --full        Detailed diagnostic info

Configuration:
  shelldone config show          View current config file
  shelldone config set K V       Set a config value
  shelldone config get K         Get a config value with source
  shelldone config list          List all settings with sources
  shelldone config init          Output default config template
  shelldone config edit          Open config in editor
  shelldone channel add <name>   Guided channel setup
  shelldone channel list         Show all channel statuses
  shelldone channel test <name>  Test a channel
  shelldone exclude [list|add|remove]  Manage auto-notify exclusions

Daily Use:
  alert <command>                Wrap command with notifications
  alert --on-failure <command>   Notify only on failure
  alert-bg [PID|%jobspec]       Monitor background job
  (auto-notify)                  Commands >10s auto-notify on completion

Notification Control:
  shelldone mute [channel] [duration]  Mute notifications (e.g., slack 2h)
  shelldone unmute [channel]           Resume notifications (or unmute all)
  shelldone toggle [layer [on|off]]  Toggle notification layers
  shelldone schedule [HH:MM-HH:MM|off]  Set daily quiet hours

  Layers: desktop, sound, voice, slack, discord, telegram, email,
          whatsapp, webhook, external (group),
          claude, codex, gemini, copilot, cursor (AI CLIs)

AI CLI Hooks:
  shelldone setup ai-hooks       Install hooks for all detected AI CLIs
  shelldone setup <ai>-hook      Install a specific AI CLI hook
  shelldone toggle claude off    Disable notifications from Claude
  Available: claude, codex, gemini, copilot, cursor
  Aider: no native hooks - use: alert aider <prompt>

Other:
  shelldone init [bash|zsh]      Output shell init code (use with eval)
  shelldone webhook [status|test]  Manage external channels (legacy)
  shelldone history [show|--clear] View notification history
  shelldone sounds               List available system sounds
  shelldone uninstall [--yes]    Remove shell integration + hooks
  shelldone version [--verbose]  Show version
  shelldone help                 Show this help

Config (env vars, set before eval):
  SHELLDONE_ENABLED=true         Master on/off switch
  SHELLDONE_AUTO=true            Auto-notify on/off
  SHELLDONE_THRESHOLD=10         Seconds before auto-notify triggers
  SHELLDONE_NOTIFY_ON=all        Notify filter: all, failure, success
  SHELLDONE_SOUND_SUCCESS=Glass  Success sound name or file path
  SHELLDONE_SOUND_FAILURE=Sosumi Failure sound name or file path
  SHELLDONE_VOICE=true           Enable TTS announcements
  SHELLDONE_EXCLUDE="vim ssh"    Commands to skip (supports globs)
  SHELLDONE_FOCUS_DETECT=true    Suppress when terminal focused
  SHELLDONE_HISTORY=true         Log notifications to history file

External channels (env vars or shelldone channel add):
  SHELLDONE_SLACK_WEBHOOK=...    Slack incoming webhook URL
  SHELLDONE_DISCORD_WEBHOOK=...  Discord webhook URL
  SHELLDONE_TELEGRAM_TOKEN=...   Telegram bot token (also set _CHAT_ID)
  SHELLDONE_EMAIL_TO=...         Email recipient (requires sendmail/mail)
  SHELLDONE_WHATSAPP_TOKEN=...   Twilio auth (also set _API_URL, _FROM, _TO)
  SHELLDONE_WEBHOOK_URL=...      Generic webhook endpoint
HELP
}

# ── Config set/get helpers (Step 4) ──────────────────────────────────────────

_SHELLDONE_VALID_KEYS="SHELLDONE_ENABLED SHELLDONE_AUTO SHELLDONE_THRESHOLD SHELLDONE_NOTIFY_ON SHELLDONE_SOUND_SUCCESS SHELLDONE_SOUND_FAILURE SHELLDONE_VOICE SHELLDONE_FOCUS_DETECT SHELLDONE_HISTORY SHELLDONE_EXCLUDE SHELLDONE_ACTIVATE SHELLDONE_QUIET_HOURS SHELLDONE_SOUND_TIMEOUT SHELLDONE_DEBUG SHELLDONE_TERMINALS SHELLDONE_RATE_LIMIT SHELLDONE_WEBHOOK_TIMEOUT SHELLDONE_SLACK_WEBHOOK SHELLDONE_DISCORD_WEBHOOK SHELLDONE_TELEGRAM_TOKEN SHELLDONE_TELEGRAM_CHAT_ID SHELLDONE_EMAIL_TO SHELLDONE_WHATSAPP_TOKEN SHELLDONE_WHATSAPP_API_URL SHELLDONE_WHATSAPP_FROM SHELLDONE_WHATSAPP_TO SHELLDONE_WEBHOOK_URL"

_config_ensure_file() {
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/shelldone"
  local config_file="${SHELLDONE_CONFIG:-${config_dir}/config}"
  if [[ ! -f "$config_file" ]]; then
    mkdir -p "$config_dir"
    cmd_config init > "$config_file"
  fi
  echo "$config_file"
}

_config_is_export_key() {
  local key="$1"
  case "$key" in
    SHELLDONE_SLACK_WEBHOOK|SHELLDONE_DISCORD_WEBHOOK|SHELLDONE_TELEGRAM_TOKEN|\
    SHELLDONE_TELEGRAM_CHAT_ID|SHELLDONE_EMAIL_TO|SHELLDONE_WHATSAPP_TOKEN|\
    SHELLDONE_WHATSAPP_API_URL|SHELLDONE_WHATSAPP_FROM|SHELLDONE_WHATSAPP_TO|\
    SHELLDONE_WEBHOOK_URL)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

_config_set_value() {
  local key="$1" value="$2"
  local config_file
  config_file="$(_config_ensure_file)"

  # Build the line to write
  local new_line
  if _config_is_export_key "$key"; then
    new_line="export ${key}=\"${value}\""
  else
    new_line=": \"\${${key}:=${value}}\""
  fi

  local tmp_file
  tmp_file=$(mktemp)
  _SHELLDONE_TMPFILES+=("$tmp_file")

  local found=false
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Match lines containing this key (commented or uncommented)
    local match=false
    case "$line" in
      *"${key}"*) match=true ;;
    esac
    # Only match if it's a config line (: "${KEY:=...}" or export KEY=...)
    if $match; then
      case "$line" in
        *": \"\${"*|*"export ${key}="*|*"# : \"\${"*|*"# export ${key}="*)
          printf '%s\n' "$new_line" >> "$tmp_file"
          found=true
          continue
          ;;
      esac
    fi
    printf '%s\n' "$line" >> "$tmp_file"
  done < "$config_file"

  if ! $found; then
    # Append at end
    printf '%s\n' "$new_line" >> "$tmp_file"
  fi

  mv "$tmp_file" "$config_file"
}

_config_get_value() {
  local key="$1"
  local config_file="${SHELLDONE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/shelldone/config}"

  # Check env first
  local env_val="${!key:-}"
  if [[ -n "$env_val" ]]; then
    printf '%s (env)\n' "$env_val"
    return 0
  fi

  # Check config file
  if [[ -f "$config_file" ]]; then
    local line
    while IFS= read -r line; do
      # Skip comments
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      # Match : "${KEY:=value}" pattern
      if [[ "$line" =~ ${key}:=([^\}\"]*) ]]; then
        printf '%s (config)\n' "${BASH_REMATCH[1]}"
        return 0
      fi
      # Match export KEY="value" pattern
      if [[ "$line" =~ ^export[[:space:]]+${key}=\"([^\"]*)\" ]]; then
        printf '%s (config)\n' "${BASH_REMATCH[1]}"
        return 0
      fi
    done < "$config_file"
  fi

  echo "(not set)"
}

# ── Doctor command (Step 2) ──────────────────────────────────────────────────

cmd_doctor() {
  local passes=0 warnings=0 errors=0

  _doctor_pass() { passes=$((passes + 1)); printf '    %s\n' "$(_tui_ok "$1")"; }
  _doctor_warn() { warnings=$((warnings + 1)); printf '    %s\n' "$(_tui_warn "$1")"; }
  _doctor_fail() { errors=$((errors + 1)); printf '    %s\n' "$(_tui_err "$1")"; }
  _doctor_fix()  { printf '      Fix: %s\n' "$1"; }

  # Shell Integration
  _tui_header "  Shell Integration"
  local rc
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    local name
    name="$(basename "$rc")"
    if [[ -f "$rc" ]] && grep -qF "$_SHELLDONE_MARKER_BEGIN" "$rc" 2>/dev/null; then
      _doctor_pass "$name has shelldone block"
    elif [[ -f "$rc" ]]; then
      _doctor_warn "$name exists but missing shelldone block"
      _doctor_fix "shelldone setup"
    fi
  done

  if command -v shelldone &>/dev/null; then
    _doctor_pass "shelldone is on PATH"
  else
    _doctor_fail "shelldone not found on PATH"
    _doctor_fix "Add to PATH or re-run install"
  fi

  # Notification Tools
  _tui_header "  Notification Tools"
  (
    unset _SHELLDONE_LOADED
    source "${SHELLDONE_LIB}/shelldone.sh"
    case "$_SHELLDONE_PLATFORM" in
      darwin)
        if command -v osascript &>/dev/null; then
          _doctor_pass "osascript available"
        else
          _doctor_fail "osascript not found"
        fi
        if command -v terminal-notifier &>/dev/null; then
          _doctor_pass "terminal-notifier available"
        else
          _doctor_warn "terminal-notifier not installed (optional, enhances notifications)"
          _doctor_fix "brew install terminal-notifier"
        fi
        ;;
      linux)
        if command -v notify-send &>/dev/null; then
          _doctor_pass "notify-send available"
        else
          _doctor_warn "notify-send not found"
          _doctor_fix "Install libnotify (e.g., apt install libnotify-bin)"
        fi
        ;;
      wsl|windows)
        if command -v powershell.exe &>/dev/null; then
          _doctor_pass "powershell.exe available"
        else
          _doctor_warn "powershell.exe not found"
        fi
        ;;
    esac
  )

  # Config File
  _tui_header "  Configuration"
  local config_file="${SHELLDONE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/shelldone/config}"
  if [[ -f "$config_file" ]]; then
    if bash -n "$config_file" 2>/dev/null; then
      _doctor_pass "Config file exists and parses ($config_file)"
    else
      _doctor_fail "Config file has syntax errors"
      _doctor_fix "shelldone config edit"
    fi
  else
    _doctor_warn "Config file not found"
    _doctor_fix "shelldone config set SHELLDONE_THRESHOLD 10"
  fi

  # HTTP Transport
  _tui_header "  HTTP Transport"
  if command -v curl &>/dev/null; then
    _doctor_pass "curl available"
  elif command -v wget &>/dev/null; then
    _doctor_pass "wget available"
  else
    _doctor_warn "Neither curl nor wget found (required for external channels)"
    _doctor_fix "Install curl for external notification channels"
  fi

  # External Channels
  _tui_header "  External Channels"
  local channel_checked=false
  if [[ -n "${SHELLDONE_SLACK_WEBHOOK:-}" ]]; then
    _doctor_pass "Slack webhook configured"
    channel_checked=true
  fi
  if [[ -n "${SHELLDONE_DISCORD_WEBHOOK:-}" ]]; then
    _doctor_pass "Discord webhook configured"
    channel_checked=true
  fi
  if [[ -n "${SHELLDONE_TELEGRAM_TOKEN:-}" ]]; then
    if [[ -n "${SHELLDONE_TELEGRAM_CHAT_ID:-}" ]]; then
      _doctor_pass "Telegram configured (token + chat ID)"
      channel_checked=true
    else
      _doctor_warn "Telegram: token set but SHELLDONE_TELEGRAM_CHAT_ID missing"
      _doctor_fix "shelldone channel add telegram"
      channel_checked=true
    fi
  fi
  if [[ -n "${SHELLDONE_EMAIL_TO:-}" ]]; then
    _doctor_pass "Email configured (${SHELLDONE_EMAIL_TO})"
    channel_checked=true
  fi
  if [[ -n "${SHELLDONE_WHATSAPP_TOKEN:-}" ]]; then
    local wa_ok=true
    [[ -z "${SHELLDONE_WHATSAPP_API_URL:-}" ]] && wa_ok=false
    [[ -z "${SHELLDONE_WHATSAPP_FROM:-}" ]] && wa_ok=false
    [[ -z "${SHELLDONE_WHATSAPP_TO:-}" ]] && wa_ok=false
    if $wa_ok; then
      _doctor_pass "WhatsApp configured"
    else
      _doctor_warn "WhatsApp: token set but missing API_URL, FROM, or TO"
      _doctor_fix "shelldone channel add whatsapp"
    fi
    channel_checked=true
  fi
  if [[ -n "${SHELLDONE_WEBHOOK_URL:-}" ]]; then
    _doctor_pass "Generic webhook configured"
    channel_checked=true
  fi
  if ! $channel_checked; then
    printf '    %s\n' "$(_tui_info "No external channels configured (optional)")"
  fi

  # AI CLI Hooks
  _tui_header "  AI CLI Hooks"
  local ai_i
  for ai_i in "${!_SHELLDONE_AI_NAMES[@]}"; do
    local ai_name="${_SHELLDONE_AI_NAMES[$ai_i]}"
    local ai_label="${_SHELLDONE_AI_LABELS[$ai_i]}"
    local ai_hook="${_SHELLDONE_AI_HOOKS[$ai_i]}"
    local ai_cmd="${_SHELLDONE_AI_CMDS[$ai_i]}"
    local ai_settings="${_SHELLDONE_AI_SETTINGS[$ai_i]}"
    local ai_config_dir="${_SHELLDONE_AI_CONFIGDIRS[$ai_i]}"

    [[ -z "$ai_hook" ]] && continue

    if ! command -v "$ai_cmd" &>/dev/null && [[ -z "$ai_config_dir" || ! -d "$ai_config_dir" ]]; then
      continue  # Not detected, skip silently
    fi

    local hook_file="${SHELLDONE_HOOKS}/${ai_hook}"
    local hook_installed=false
    if [[ "$ai_name" == "copilot" ]]; then
      local copilot_hook="$HOME/.github/hooks/shelldone-session-end.json"
      [[ -f "$copilot_hook" ]] && grep -q "copilot-done" "$copilot_hook" 2>/dev/null && hook_installed=true
    elif [[ -n "$ai_settings" && -f "$ai_settings" ]]; then
      local hook_basename
      hook_basename=$(basename "$hook_file")
      grep -q "${hook_basename%.sh}" "$ai_settings" 2>/dev/null && hook_installed=true
    fi

    if $hook_installed; then
      _doctor_pass "${ai_label} hook installed"
    else
      _doctor_warn "${ai_label} detected but hook not installed"
      _doctor_fix "shelldone setup ${ai_name}-hook"
    fi
  done

  # Permissions
  _tui_header "  Permissions"
  local bin_path
  bin_path="$(cd "$(dirname "$0")" && pwd)/shelldone"
  if [[ -x "$bin_path" ]]; then
    _doctor_pass "shelldone is executable"
  else
    _doctor_fail "shelldone is not executable"
    _doctor_fix "chmod +x $bin_path"
  fi

  # Summary
  printf '\n  %sSummary:%s %s%d passed%s' "${_TUI_BOLD}" "${_TUI_RESET}" "${_TUI_GREEN}" "$passes" "${_TUI_RESET}"
  if [[ $warnings -gt 0 ]]; then
    printf ', %s%d warnings%s' "${_TUI_YELLOW}" "$warnings" "${_TUI_RESET}"
  fi
  if [[ $errors -gt 0 ]]; then
    printf ', %s%d errors%s' "${_TUI_RED}" "$errors" "${_TUI_RESET}"
  fi
  printf '\n\n'

  [[ $errors -eq 0 ]]
}

# ── Channel command (Step 5) ─────────────────────────────────────────────────

cmd_channel() {
  local action="${1:-list}"

  case "$action" in
    list)
      (
        unset _SHELLDONE_LOADED
        source "${SHELLDONE_LIB}/shelldone.sh"
        _tui_header "External Channels"
        local -a channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
        local -a envvars=("SHELLDONE_SLACK_WEBHOOK" "SHELLDONE_DISCORD_WEBHOOK" "SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_EMAIL_TO" "SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WEBHOOK_URL")
        local i
        for i in "${!channels[@]}"; do
          local ch="${channels[$i]}"
          local ev="${envvars[$i]}"
          if [[ -n "${!ev:-}" ]]; then
            printf '  %s✓%s %-12s configured\n' "${_TUI_GREEN}" "${_TUI_RESET}" "$ch"
          else
            printf '  %s-%s %-12s not configured\n' "${_TUI_DIM}" "${_TUI_RESET}" "$ch"
          fi
        done
        echo ""
        printf '  Tip: Run %sshelldone channel add <name>%s for guided setup\n' "${_TUI_BOLD}" "${_TUI_RESET}"
        echo ""
      )
      ;;
    add)
      local channel="${2:-}"
      if [[ -z "$channel" ]]; then
        echo >&2 "Usage: shelldone channel add <name>"
        echo >&2 "Channels: slack discord telegram email whatsapp webhook"
        exit 1
      fi
      _channel_setup "$channel"
      ;;
    remove)
      local channel="${2:-}"
      if [[ -z "$channel" ]]; then
        echo >&2 "Usage: shelldone channel remove <name>"
        exit 1
      fi
      _channel_remove "$channel"
      ;;
    test)
      local channel="${2:-}"
      if [[ -z "$channel" ]]; then
        echo >&2 "Usage: shelldone channel test <name>"
        exit 1
      fi
      # Delegate to webhook test
      cmd_webhook test "$channel"
      ;;
    *)
      echo >&2 "Usage: shelldone channel [list|add <name>|remove <name>|test <name>]"
      exit 1
      ;;
  esac
}

_channel_setup() {
  local channel="$1"
  case "$channel" in
    slack)    _channel_setup_slack ;;
    discord)  _channel_setup_discord ;;
    telegram) _channel_setup_telegram ;;
    email)    _channel_setup_email ;;
    whatsapp) _channel_setup_whatsapp ;;
    webhook)  _channel_setup_webhook ;;
    *)
      echo >&2 "Unknown channel: $channel"
      echo >&2 "Available: slack discord telegram email whatsapp webhook"
      exit 1
      ;;
  esac
}

_channel_setup_slack() {
  _tui_header "Slack Setup"
  echo ""
  echo "  To get a Slack webhook URL:"
  echo "  1. Go to https://api.slack.com/apps"
  echo "  2. Create an app (or select existing) -> Incoming Webhooks"
  echo "  3. Activate and add a new webhook to your workspace"
  echo "  4. Copy the webhook URL"
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_SLACK_WEBHOOK manually."
    return 1
  fi

  local url
  url=$(_tui_prompt "Webhook URL")
  url=$(_tui_sanitize_url "$url")
  if [[ -z "$url" ]]; then
    echo "Cancelled."
    return 1
  fi
  if [[ ! "$url" =~ ^https://hooks\.slack\.com/ ]]; then
    _tui_warn "URL doesn't look like a Slack webhook (expected https://hooks.slack.com/...)"
    if ! _tui_confirm "Save anyway?"; then
      return 1
    fi
  fi

  _config_set_value "SHELLDONE_SLACK_WEBHOOK" "$url"
  _tui_ok "Slack webhook saved to config"

  # Test
  if _tui_confirm "Send a test message?" "default_yes"; then
    export SHELLDONE_SLACK_WEBHOOK="$url"
    cmd_webhook test slack
  fi
}

_channel_setup_discord() {
  _tui_header "Discord Setup"
  echo ""
  echo "  To get a Discord webhook URL:"
  echo "  1. Open Server Settings -> Integrations -> Webhooks"
  echo "  2. Create a new webhook and copy the URL"
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_DISCORD_WEBHOOK manually."
    return 1
  fi

  local url
  url=$(_tui_prompt "Webhook URL")
  url=$(_tui_sanitize_url "$url")
  if [[ -z "$url" ]]; then
    echo "Cancelled."
    return 1
  fi
  if [[ ! "$url" =~ ^https://discord\.com/api/webhooks/ ]] && [[ ! "$url" =~ ^https://discordapp\.com/api/webhooks/ ]]; then
    _tui_warn "URL doesn't look like a Discord webhook"
    if ! _tui_confirm "Save anyway?"; then
      return 1
    fi
  fi

  _config_set_value "SHELLDONE_DISCORD_WEBHOOK" "$url"
  _tui_ok "Discord webhook saved to config"

  if _tui_confirm "Send a test message?" "default_yes"; then
    export SHELLDONE_DISCORD_WEBHOOK="$url"
    cmd_webhook test discord
  fi
}

_channel_setup_telegram() {
  _tui_header "Telegram Setup"
  echo ""
  echo "  To set up Telegram notifications:"
  echo "  1. Message @BotFather on Telegram to create a bot"
  echo "  2. Copy the bot token"
  echo "  3. Start a chat with your bot, then get your chat ID"
  echo "     (message @userinfobot or @RawDataBot to find it)"
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_TELEGRAM_TOKEN and SHELLDONE_TELEGRAM_CHAT_ID manually."
    return 1
  fi

  local token
  token=$(_tui_prompt "Bot token")
  if [[ -z "$token" ]]; then
    echo "Cancelled."
    return 1
  fi

  local chat_id
  chat_id=$(_tui_prompt "Chat ID")
  if [[ -z "$chat_id" ]]; then
    echo "Cancelled."
    return 1
  fi

  _config_set_value "SHELLDONE_TELEGRAM_TOKEN" "$token"
  _config_set_value "SHELLDONE_TELEGRAM_CHAT_ID" "$chat_id"
  _tui_ok "Telegram config saved"

  if _tui_confirm "Send a test message?" "default_yes"; then
    export SHELLDONE_TELEGRAM_TOKEN="$token"
    export SHELLDONE_TELEGRAM_CHAT_ID="$chat_id"
    cmd_webhook test telegram
  fi
}

_channel_setup_email() {
  _tui_header "Email Setup"
  echo ""
  echo "  Email notifications require sendmail or mail to be available."

  if ! command -v sendmail &>/dev/null && ! command -v mail &>/dev/null; then
    _tui_err "Neither sendmail nor mail found. Install one first."
    return 1
  fi
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_EMAIL_TO manually."
    return 1
  fi

  local email
  email=$(_tui_prompt "Recipient email address")
  if [[ -z "$email" ]]; then
    echo "Cancelled."
    return 1
  fi

  _config_set_value "SHELLDONE_EMAIL_TO" "$email"
  _tui_ok "Email recipient saved to config"

  if _tui_confirm "Send a test email?" "default_yes"; then
    export SHELLDONE_EMAIL_TO="$email"
    cmd_webhook test email
  fi
}

_channel_setup_whatsapp() {
  _tui_header "WhatsApp Setup (via Twilio)"
  echo ""
  echo "  WhatsApp notifications use the Twilio API."
  echo "  You need a Twilio account with WhatsApp sandbox or approved sender."
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_WHATSAPP_* vars manually."
    return 1
  fi

  local api_url token from_num to_num

  api_url=$(_tui_prompt "Twilio API URL" "https://api.twilio.com/2010-04-01/Accounts/YOUR_SID/Messages.json")
  api_url=$(_tui_sanitize_url "$api_url")
  [[ -z "$api_url" ]] && { echo "Cancelled."; return 1; }

  token=$(_tui_prompt_secret "Twilio Auth Token")
  [[ -z "$token" ]] && { echo "Cancelled."; return 1; }

  from_num=$(_tui_prompt "From number (e.g., whatsapp:+14155238886)")
  [[ -z "$from_num" ]] && { echo "Cancelled."; return 1; }

  to_num=$(_tui_prompt "To number (e.g., whatsapp:+1234567890)")
  [[ -z "$to_num" ]] && { echo "Cancelled."; return 1; }

  _config_set_value "SHELLDONE_WHATSAPP_API_URL" "$api_url"
  _config_set_value "SHELLDONE_WHATSAPP_TOKEN" "$token"
  _config_set_value "SHELLDONE_WHATSAPP_FROM" "$from_num"
  _config_set_value "SHELLDONE_WHATSAPP_TO" "$to_num"
  _tui_ok "WhatsApp config saved"

  if _tui_confirm "Send a test message?" "default_yes"; then
    export SHELLDONE_WHATSAPP_API_URL="$api_url"
    export SHELLDONE_WHATSAPP_TOKEN="$token"
    export SHELLDONE_WHATSAPP_FROM="$from_num"
    export SHELLDONE_WHATSAPP_TO="$to_num"
    cmd_webhook test whatsapp
  fi
}

_channel_setup_webhook() {
  _tui_header "Generic Webhook Setup"
  echo ""
  echo "  shelldone will POST JSON to your endpoint on each notification."
  echo ""

  if ! _tui_is_interactive; then
    echo "Non-interactive mode. Set SHELLDONE_WEBHOOK_URL manually."
    return 1
  fi

  local url
  url=$(_tui_prompt "Webhook URL")
  url=$(_tui_sanitize_url "$url")
  if [[ -z "$url" ]]; then
    echo "Cancelled."
    return 1
  fi
  if ! _tui_validate_url "$url"; then
    _tui_warn "URL doesn't look valid (expected http:// or https://)"
    if ! _tui_confirm "Save anyway?"; then
      return 1
    fi
  fi

  _config_set_value "SHELLDONE_WEBHOOK_URL" "$url"
  _tui_ok "Webhook URL saved to config"

  if _tui_confirm "Send a test message?" "default_yes"; then
    export SHELLDONE_WEBHOOK_URL="$url"
    cmd_webhook test webhook
  fi
}

_channel_remove() {
  local channel="$1"
  local key
  case "$channel" in
    slack)    key="SHELLDONE_SLACK_WEBHOOK" ;;
    discord)  key="SHELLDONE_DISCORD_WEBHOOK" ;;
    telegram) key="SHELLDONE_TELEGRAM_TOKEN" ;;
    email)    key="SHELLDONE_EMAIL_TO" ;;
    whatsapp) key="SHELLDONE_WHATSAPP_TOKEN" ;;
    webhook)  key="SHELLDONE_WEBHOOK_URL" ;;
    *)
      echo >&2 "Unknown channel: $channel"
      exit 1
      ;;
  esac

  if _tui_is_interactive; then
    if ! _tui_confirm "Remove ${channel} channel from config?"; then
      echo "Cancelled."
      return 0
    fi
  fi

  local config_file="${SHELLDONE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/shelldone/config}"
  if [[ ! -f "$config_file" ]]; then
    echo "No config file found."
    return 0
  fi

  # Comment out all keys for this channel
  local tmp_file
  tmp_file=$(mktemp)
  _SHELLDONE_TMPFILES+=("$tmp_file")

  case "$channel" in
    telegram)
      local -a keys_to_remove=("SHELLDONE_TELEGRAM_TOKEN" "SHELLDONE_TELEGRAM_CHAT_ID") ;;
    whatsapp)
      local -a keys_to_remove=("SHELLDONE_WHATSAPP_TOKEN" "SHELLDONE_WHATSAPP_API_URL" "SHELLDONE_WHATSAPP_FROM" "SHELLDONE_WHATSAPP_TO") ;;
    *)
      local -a keys_to_remove=("$key") ;;
  esac

  while IFS= read -r line || [[ -n "$line" ]]; do
    local should_comment=false
    local k
    for k in "${keys_to_remove[@]}"; do
      if [[ "$line" =~ ^export[[:space:]]+${k}= ]] || [[ "$line" =~ ^:[[:space:]]+\"\$\{${k}: ]]; then
        should_comment=true
        break
      fi
    done
    if $should_comment; then
      printf '# %s\n' "$line" >> "$tmp_file"
    else
      printf '%s\n' "$line" >> "$tmp_file"
    fi
  done < "$config_file"

  mv "$tmp_file" "$config_file"
  _tui_ok "Removed ${channel} from config"
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

_SHELLDONE_COMMANDS="init setup uninstall status test-notify sounds exclude webhook channel history config doctor mute unmute toggle schedule test version help"

case "${1:-help}" in
  init)        shift; cmd_init "$@" ;;
  setup)       shift; cmd_setup "$@" ;;
  uninstall)   shift; cmd_uninstall "$@" ;;
  status)      shift; cmd_status "$@" ;;
  test-notify) shift; cmd_test_notify "$@" ;;
  sounds)      shift; cmd_sounds "$@" ;;
  exclude)     shift; cmd_exclude "$@" ;;
  webhook)     shift; cmd_webhook "$@" ;;
  channel)     shift; cmd_channel "$@" ;;
  history)     shift; cmd_history "$@" ;;
  config)      shift; cmd_config "$@" ;;
  doctor)      shift; cmd_doctor "$@" ;;
  mute)        shift; cmd_mute "$@" ;;
  unmute)      shift; cmd_unmute "$@" ;;
  toggle)      shift; cmd_toggle "$@" ;;
  schedule)    shift; cmd_schedule "$@" ;;
  test)        shift; cmd_test "$@" ;;
  version|--version|-v) shift 2>/dev/null; cmd_version "$@" ;;
  help|--help|-h)       cmd_help ;;
  *)
    # "Did you mean?" suggestion (Step 8)
    _input="$1"
    _suggestion=""
    for _cmd in $_SHELLDONE_COMMANDS; do
      # Prefix match
      if [[ "$_cmd" == "${_input}"* ]]; then
        _suggestion="$_cmd"
        break
      fi
    done
    if [[ -z "$_suggestion" ]] && [[ ${#_input} -ge 3 ]]; then
      # Check if first 3 chars match any command
      _prefix="${_input:0:3}"
      for _cmd in $_SHELLDONE_COMMANDS; do
        if [[ "${_cmd:0:3}" == "$_prefix" ]]; then
          _suggestion="$_cmd"
          break
        fi
      done
    fi
    if [[ -n "$_suggestion" ]]; then
      echo >&2 "shelldone: unknown command '${_input}'. Did you mean '${_suggestion}'?"
    else
      echo >&2 "shelldone: unknown command '${_input}'"
      echo >&2 ""
      echo >&2 "Commands: $_SHELLDONE_COMMANDS"
    fi
    echo >&2 "Run 'shelldone help' for usage"
    exit 1
    ;;
esac
