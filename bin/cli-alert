#!/usr/bin/env bash
# cli-alert — Terminal process completion notifier
# Usage: cli-alert <command> [args...]
set -euo pipefail

# ── Temp file cleanup ──────────────────────────────────────────────────────
_CLI_ALERT_TMPFILES=()
_cli_alert_cleanup() {
  local f
  for f in "${_CLI_ALERT_TMPFILES[@]+"${_CLI_ALERT_TMPFILES[@]}"}"; do
    rm -f "$f" 2>/dev/null
  done
}
trap _cli_alert_cleanup EXIT

# ── Marker constants ───────────────────────────────────────────────────────
readonly _CLI_ALERT_MARKER_BEGIN="# >>> cli-alert >>>"
readonly _CLI_ALERT_MARKER_END="# <<< cli-alert <<<"

# ── VERSION lookup (multi-path) ───────────────────────────────────────────
_cli_alert_resolve_version() {
  local bin_path="$0"
  if command -v readlink &>/dev/null; then
    bin_path="$(readlink -f "$bin_path" 2>/dev/null || readlink "$bin_path" 2>/dev/null || echo "$bin_path")"
  fi
  local prefix
  prefix="$(cd "$(dirname "$bin_path")/.." && pwd)"

  local candidate
  for candidate in \
    "${prefix}/VERSION" \
    "${prefix}/share/cli-alert/VERSION" \
    "/usr/share/cli-alert/VERSION"; do
    if [[ -f "$candidate" ]]; then
      cat "$candidate"
      return
    fi
  done
  echo "0.1.0"
}

CLI_ALERT_VERSION="$(_cli_alert_resolve_version)"

# Resolve the lib directory (works whether installed or run from source)
_cli_alert_resolve_lib() {
  local bin_path="$0"
  # Follow symlinks (portable)
  if command -v readlink &>/dev/null; then
    bin_path="$(readlink -f "$bin_path" 2>/dev/null || readlink "$bin_path" 2>/dev/null || echo "$bin_path")"
  fi
  local bin_dir
  bin_dir="$(cd "$(dirname "$bin_path")" && pwd)"

  # Try: <prefix>/lib/cli-alert/ (package manager install)
  if [[ -f "${bin_dir}/../lib/cli-alert/cli-alert.sh" ]]; then
    echo "${bin_dir}/../lib/cli-alert"
  # Try: <repo>/lib/ (running from source)
  elif [[ -f "${bin_dir}/../lib/cli-alert.sh" ]]; then
    echo "${bin_dir}/../lib"
  else
    echo >&2 "cli-alert: cannot find lib directory"
    exit 1
  fi
}

CLI_ALERT_LIB="$(_cli_alert_resolve_lib)"

# ── AI CLI Registry ──────────────────────────────────────────────────────────
# Parallel arrays (bash 3.2 compatible — no associative arrays)
# Index: 0=claude 1=codex 2=gemini 3=copilot 4=cursor 5=aider

_CLI_ALERT_AI_NAMES=("claude" "codex" "gemini" "copilot" "cursor" "aider")
_CLI_ALERT_AI_LABELS=("Claude Code" "Codex CLI" "Gemini CLI" "Copilot CLI" "Cursor" "Aider")
_CLI_ALERT_AI_HOOKS=("claude-done.sh" "codex-done.sh" "gemini-done.sh" "copilot-done.sh" "cursor-done.sh" "")
_CLI_ALERT_AI_CMDS=("claude" "codex" "gemini" "gh" "cursor" "aider")
_CLI_ALERT_AI_SETTINGS=("$HOME/.claude/settings.json" "$HOME/.codex/config.json" "$HOME/.gemini/settings.json" "" "$HOME/.cursor/hooks.json" "")
_CLI_ALERT_AI_CONFIGDIRS=("$HOME/.claude" "$HOME/.codex" "$HOME/.gemini" "$HOME/.github" "$HOME/.cursor" "")

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
  local shell="${1:-}"

  # Auto-detect shell if not specified
  if [[ -z "$shell" ]]; then
    local parent
    parent="$(ps -p $PPID -o comm= 2>/dev/null || echo "")"
    case "$parent" in
      *zsh*)  shell="zsh" ;;
      *bash*) shell="bash" ;;
      *)
        # Fall back to $SHELL
        case "${SHELL:-}" in
          *zsh)  shell="zsh" ;;
          *bash) shell="bash" ;;
          *)
            echo >&2 "cli-alert: cannot detect shell. Usage: cli-alert init [bash|zsh]"
            exit 1
            ;;
        esac
        ;;
    esac
  fi

  local lib_path
  lib_path="$(cd "$CLI_ALERT_LIB" && pwd)"

  case "$shell" in
    zsh)
      cat <<INITEOF
# cli-alert shell integration
export _CLI_ALERT_LIB="${lib_path}"
source "${lib_path}/cli-alert.sh"
source "${lib_path}/auto-notify.zsh"
INITEOF
      ;;
    bash)
      cat <<INITEOF
# cli-alert shell integration
export _CLI_ALERT_LIB="${lib_path}"
source "${lib_path}/cli-alert.sh"
source "${lib_path}/auto-notify.bash"
INITEOF
      ;;
    *)
      echo >&2 "cli-alert: unsupported shell '$shell'. Supported: bash, zsh"
      exit 1
      ;;
  esac
}

cmd_setup() {
  local action="${1:-}"

  case "$action" in
    claude-hook)
      _setup_claude_hook
      ;;
    codex-hook)
      _setup_codex_hook
      ;;
    gemini-hook)
      _setup_gemini_hook
      ;;
    copilot-hook)
      _setup_copilot_hook
      ;;
    cursor-hook)
      _setup_cursor_hook
      ;;
    ai-hooks)
      _setup_ai_hooks
      ;;
    ""|all)
      _setup_shell_init
      _setup_ai_hooks
      echo ""
      printf '\033[1;32m[cli-alert]\033[0m Setup complete!\n'
      printf '\033[1;34m[cli-alert]\033[0m Restart your shell or run: exec %s\n' "$(basename "$SHELL")"
      ;;
    *)
      echo >&2 "Usage: cli-alert setup [all|ai-hooks|claude-hook|codex-hook|gemini-hook|copilot-hook|cursor-hook]"
      exit 1
      ;;
  esac
}

_setup_shell_init() {
  local bin_path bin_dir
  bin_path="$(cd "$(dirname "$0")" && pwd)/cli-alert"
  bin_dir="$(dirname "$bin_path")"

  _add_to_rc() {
    local rc_file="$1" shell_name="$2"

    if grep -qF "$_CLI_ALERT_MARKER_BEGIN" "$rc_file" 2>/dev/null; then
      printf '\033[1;34m[cli-alert]\033[0m Already in %s, skipping\n' "$(basename "$rc_file")"
      return 0
    fi

    {
      echo ""
      echo "$_CLI_ALERT_MARKER_BEGIN"
      echo "export PATH=\"${bin_dir}:\$PATH\""
      echo "eval \"\$(${bin_path} init ${shell_name})\""
      echo "$_CLI_ALERT_MARKER_END"
    } >> "$rc_file"

    printf '\033[1;32m[cli-alert]\033[0m Added to %s\n' "$rc_file"
  }

  # Detect which rc files to modify
  if [[ -f "$HOME/.zshrc" ]] || [[ "$(basename "${SHELL:-}" 2>/dev/null)" == "zsh" ]]; then
    _add_to_rc "$HOME/.zshrc" "zsh"
  fi
  if [[ -f "$HOME/.bashrc" ]] || [[ "$(basename "${SHELL:-}" 2>/dev/null)" == "bash" ]]; then
    _add_to_rc "$HOME/.bashrc" "bash"
  fi
}

_setup_claude_hook() {
  local hook_cmd
  hook_cmd="$(cd "$(dirname "$0")/.." && pwd)/hooks/claude-done.sh"
  local claude_settings="$HOME/.claude/settings.json"

  if [[ ! -f "$hook_cmd" ]]; then
    echo >&2 "cli-alert: hook script not found at $hook_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[cli-alert]\033[0m python3 not found — skipping Claude Code hook\n'
    printf '\033[1;33m[cli-alert]\033[0m Manually add to %s\n' "$claude_settings"
    return 0
  fi

  if [[ ! -f "$claude_settings" ]]; then
    mkdir -p "$(dirname "$claude_settings")"
    echo '{}' > "$claude_settings"
  fi

  local result
  result=$(python3 - "$claude_settings" "$hook_cmd" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
hook_cmd = sys.argv[2]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", {})
stop_hooks = hooks.setdefault("Stop", [])

for entry in stop_hooks:
    for h in entry.get("hooks", []):
        if h.get("command", "") == hook_cmd:
            print("ALREADY_INSTALLED")
            sys.exit(0)

hook_entry = {"hooks": [{"type": "command", "command": hook_cmd}]}
stop_hooks.append(hook_entry)

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
print("INSTALLED")
PYEOF
  )

  if [[ "$result" == "ALREADY_INSTALLED" ]]; then
    printf '\033[1;34m[cli-alert]\033[0m Claude Code hook already installed\n'
  else
    printf '\033[1;32m[cli-alert]\033[0m Added Claude Code Stop hook\n'
  fi
}

_setup_codex_hook() {
  local hook_cmd
  hook_cmd="$(cd "$(dirname "$0")/.." && pwd)/hooks/codex-done.sh"
  local codex_settings="$HOME/.codex/config.json"

  if [[ ! -f "$hook_cmd" ]]; then
    echo >&2 "cli-alert: hook script not found at $hook_cmd"
    return 1
  fi

