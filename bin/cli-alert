import sys, json

settings_path = sys.argv[1]
hook_cmd = sys.argv[2]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", {})
stop_hooks = hooks.setdefault("Stop", [])

for entry in stop_hooks:
    for h in entry.get("hooks", []):
        if h.get("command", "") == hook_cmd:
            print("ALREADY_INSTALLED")
            sys.exit(0)

hook_entry = {"hooks": [{"type": "command", "command": hook_cmd}]}
stop_hooks.append(hook_entry)

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
print("INSTALLED")
PYEOF
  )

  if [[ "$result" == "ALREADY_INSTALLED" ]]; then
    printf '\033[1;34m[cli-alert]\033[0m Codex CLI hook already installed\n'
  else
    printf '\033[1;32m[cli-alert]\033[0m Added Codex CLI Stop hook\n'
  fi
}

_setup_gemini_hook() {
  local hook_cmd
  hook_cmd="$(cd "$(dirname "$0")/.." && pwd)/hooks/gemini-done.sh"
  local gemini_settings="$HOME/.gemini/settings.json"

  if [[ ! -f "$hook_cmd" ]]; then
    echo >&2 "cli-alert: hook script not found at $hook_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[cli-alert]\033[0m python3 not found — skipping Gemini CLI hook\n'
    printf '\033[1;33m[cli-alert]\033[0m Manually add to %s\n' "$gemini_settings"
    return 0
  fi

  if [[ ! -f "$gemini_settings" ]]; then
    mkdir -p "$(dirname "$gemini_settings")"
    echo '{}' > "$gemini_settings"
  fi

  local result
  result=$(python3 - "$gemini_settings" "$hook_cmd" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
hook_cmd = sys.argv[2]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", [])

# Check for duplicate
for entry in hooks:
    if entry.get("command", "") == hook_cmd:
        print("ALREADY_INSTALLED")
        sys.exit(0)

hook_entry = {"type": "command", "command": hook_cmd, "event": "turn_end"}
hooks.append(hook_entry)

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
print("INSTALLED")
PYEOF
  )

  if [[ "$result" == "ALREADY_INSTALLED" ]]; then
    printf '\033[1;34m[cli-alert]\033[0m Gemini CLI hook already installed\n'
  else
    printf '\033[1;32m[cli-alert]\033[0m Added Gemini CLI hook\n'
  fi
}

_setup_copilot_hook() {
  local hook_cmd
  hook_cmd="$(cd "$(dirname "$0")/.." && pwd)/hooks/copilot-done.sh"
  local hooks_dir="$HOME/.github/hooks"
  local hook_file="${hooks_dir}/cli-alert-session-end.json"

  if [[ ! -f "$hook_cmd" ]]; then
    echo >&2 "cli-alert: hook script not found at $hook_cmd"
    return 1
  fi

  mkdir -p "$hooks_dir"

  if [[ -f "$hook_file" ]] && grep -q "$hook_cmd" "$hook_file" 2>/dev/null; then
    printf '\033[1;34m[cli-alert]\033[0m Copilot CLI hook already installed\n'
    return 0
  fi

  cat > "$hook_file" << JSONEOF
{
  "event": "sessionEnd",
  "command": "$hook_cmd"
}
JSONEOF

  printf '\033[1;32m[cli-alert]\033[0m Added Copilot CLI sessionEnd hook\n'
}

_setup_cursor_hook() {
  local hook_cmd
  hook_cmd="$(cd "$(dirname "$0")/.." && pwd)/hooks/cursor-done.sh"
  local cursor_hooks="$HOME/.cursor/hooks.json"

  if [[ ! -f "$hook_cmd" ]]; then
    echo >&2 "cli-alert: hook script not found at $hook_cmd"
    return 1
  fi

  if ! command -v python3 &>/dev/null; then
    printf '\033[1;33m[cli-alert]\033[0m python3 not found — skipping Cursor hook\n'
    printf '\033[1;33m[cli-alert]\033[0m Manually add to %s\n' "$cursor_hooks"
    return 0
  fi

  if [[ ! -f "$cursor_hooks" ]]; then
    mkdir -p "$(dirname "$cursor_hooks")"
    echo '{}' > "$cursor_hooks"
  fi

  local result
  result=$(python3 - "$cursor_hooks" "$hook_cmd" << 'PYEOF'
import sys, json

hooks_path = sys.argv[1]
hook_cmd = sys.argv[2]

with open(hooks_path, 'r') as f:
    config = json.load(f)

stop_hooks = config.setdefault("stop", [])

for entry in stop_hooks:
    if entry.get("command", "") == hook_cmd:
        print("ALREADY_INSTALLED")
        sys.exit(0)

hook_entry = {"type": "command", "command": hook_cmd}
stop_hooks.append(hook_entry)

with open(hooks_path, 'w') as f:
    json.dump(config, f, indent=2)
print("INSTALLED")
PYEOF
  )

  if [[ "$result" == "ALREADY_INSTALLED" ]]; then
    printf '\033[1;34m[cli-alert]\033[0m Cursor hook already installed\n'
  else
    printf '\033[1;32m[cli-alert]\033[0m Added Cursor stop hook\n'
  fi
}

_setup_ai_hooks() {
  local i installed=0 skipped=0

  for i in "${!_CLI_ALERT_AI_NAMES[@]}"; do
    local name="${_CLI_ALERT_AI_NAMES[$i]}"
    local label="${_CLI_ALERT_AI_LABELS[$i]}"
    local hook="${_CLI_ALERT_AI_HOOKS[$i]}"
    local cmd="${_CLI_ALERT_AI_CMDS[$i]}"
    local config_dir="${_CLI_ALERT_AI_CONFIGDIRS[$i]}"

    # Skip Aider (no hooks)
    if [[ -z "$hook" ]]; then
      if command -v "$cmd" &>/dev/null; then
        printf '\033[1;34m[cli-alert]\033[0m %s detected — no native hooks, use: alert aider <prompt>\n' "$label"
      fi
      continue
    fi

    # Check if the AI CLI is installed (command exists or config dir exists)
    if command -v "$cmd" &>/dev/null || [[ -n "$config_dir" && -d "$config_dir" ]]; then
      "_setup_${name}_hook" && installed=$((installed + 1)) || true
    else
      skipped=$((skipped + 1))
    fi
  done

  if [[ $installed -gt 0 || $skipped -gt 0 ]]; then
    printf '\033[1;34m[cli-alert]\033[0m AI hooks: %d installed, %d skipped (not detected)\n' "$installed" "$skipped"
  fi
}

cmd_test() {
  local test_script
  test_script="$(cd "$(dirname "$0")/.." && pwd)/test.sh"
  if [[ -x "$test_script" ]]; then
    exec "$test_script"
  else
    echo >&2 "cli-alert: test script not found"
    exit 1
  fi
}

cmd_uninstall() {
  _remove_from_rc() {
    local rc_file="$1"

    [[ ! -f "$rc_file" ]] && return 0

    if ! grep -qF "$_CLI_ALERT_MARKER_BEGIN" "$rc_file" 2>/dev/null; then
      printf '\033[1;34m[cli-alert]\033[0m Not in %s, skipping\n' "$(basename "$rc_file")"
      return 0
    fi

    local tmp_file
    tmp_file=$(mktemp)
    _CLI_ALERT_TMPFILES+=("$tmp_file")
    local in_block=0
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "$_CLI_ALERT_MARKER_BEGIN" ]]; then
        in_block=1; continue
      fi
      if [[ "$line" == "$_CLI_ALERT_MARKER_END" ]]; then
        in_block=0; continue
      fi
      if [[ $in_block -eq 0 ]]; then
        printf '%s\n' "$line" >> "$tmp_file"
      fi
    done < "$rc_file"

    mv "$tmp_file" "$rc_file"
    printf '\033[1;32m[cli-alert]\033[0m Removed from %s\n' "$rc_file"
  }

  _remove_from_rc "$HOME/.zshrc"
  _remove_from_rc "$HOME/.bashrc"

  local base_dir
  base_dir="$(cd "$(dirname "$0")/.." && pwd)"

  # Remove Claude hook from ~/.claude/settings.json
  _uninstall_json_hook() {
    local settings_file="$1" hook_cmd="$2" label="$3" hook_key="${4:-Stop}"

    [[ -f "$settings_file" ]] || return 0
    command -v python3 &>/dev/null || return 0

    python3 - "$settings_file" "$hook_cmd" "$hook_key" << 'PYEOF'
import sys, json

settings_path = sys.argv[1]
hook_cmd = sys.argv[2]
hook_key = sys.argv[3]

with open(settings_path, 'r') as f:
    settings = json.load(f)

hooks = settings.get("hooks", {})

if isinstance(hooks, dict):
    stop_hooks = hooks.get(hook_key, [])
    new_stop = []
    removed = False
    for entry in stop_hooks:
        if isinstance(entry, dict) and "hooks" in entry:
            entry_hooks = entry.get("hooks", [])
            filtered = [h for h in entry_hooks if h.get("command", "") != hook_cmd]
            if len(filtered) < len(entry_hooks):
                removed = True
            if filtered:
                entry["hooks"] = filtered
                new_stop.append(entry)
        elif isinstance(entry, dict) and entry.get("command", "") == hook_cmd:
            removed = True
        else:
            new_stop.append(entry)
    if removed:
        if new_stop:
            hooks[hook_key] = new_stop
        else:
            hooks.pop(hook_key, None)
        if not hooks:
            settings.pop("hooks", None)
        with open(settings_path, 'w') as f:
            json.dump(settings, f, indent=2)
elif isinstance(hooks, list):
    new_hooks = [h for h in hooks if h.get("command", "") != hook_cmd]
    if len(new_hooks) < len(hooks):
        removed = True
        if new_hooks:
            settings["hooks"] = new_hooks
        else:
            settings.pop("hooks", None)
        with open(settings_path, 'w') as f:
            json.dump(settings, f, indent=2)
PYEOF
    printf '\033[1;32m[cli-alert]\033[0m Removed %s hook\n' "$label"
  }

  # Remove Claude Code hook
  _uninstall_json_hook "$HOME/.claude/settings.json" "${base_dir}/hooks/claude-done.sh" "Claude Code" "Stop"

  # Remove Codex CLI hook
  _uninstall_json_hook "$HOME/.codex/config.json" "${base_dir}/hooks/codex-done.sh" "Codex CLI" "Stop"

  # Remove Gemini CLI hook
  _uninstall_json_hook "$HOME/.gemini/settings.json" "${base_dir}/hooks/gemini-done.sh" "Gemini CLI" "hooks"

  # Remove Copilot CLI hook
  local copilot_hook_file="$HOME/.github/hooks/cli-alert-session-end.json"
  if [[ -f "$copilot_hook_file" ]]; then
    rm -f "$copilot_hook_file"
    printf '\033[1;32m[cli-alert]\033[0m Removed Copilot CLI hook\n'
  fi

  # Remove Cursor hook
  _uninstall_json_hook "$HOME/.cursor/hooks.json" "${base_dir}/hooks/cursor-done.sh" "Cursor" "stop"

  echo ""
  printf '\033[1;32m[cli-alert]\033[0m Uninstalled! Restart your shell to apply.\n'
}

cmd_version() {
  echo "cli-alert $CLI_ALERT_VERSION"
  if [[ "${1:-}" == "--verbose" || "${1:-}" == "-v" ]]; then
    (
      unset _CLI_ALERT_LOADED
      source "${CLI_ALERT_LIB}/cli-alert.sh"
      echo "  platform: $_CLI_ALERT_PLATFORM"
    )
    echo "  shell:    $(basename "${SHELL:-unknown}")"
    echo "  path:     $(cd "$(dirname "$0")" && pwd)/cli-alert"
  fi
}

cmd_status() {
  (
    unset _CLI_ALERT_LOADED
    source "${CLI_ALERT_LIB}/cli-alert.sh"

    echo "cli-alert $CLI_ALERT_VERSION"

    # Install path
    local bin_path
    bin_path="$(cd "$(dirname "$0")" && pwd)/cli-alert"
    echo "  Install path:   $bin_path"
    echo "  Platform:       $_CLI_ALERT_PLATFORM"
    echo "  Shell:          $(basename "${SHELL:-unknown}")"
    echo ""

    # Shell integration
    echo "Shell integration:"
    local rc check_mark="✓" cross_mark="-"
    for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
      local name
      name="$(basename "$rc")"
      if [[ -f "$rc" ]] && grep -qF "cli-alert" "$rc" 2>/dev/null; then
        printf '  ~/%s:%*s%s installed\n' "$name" $((14 - ${#name})) "" "$check_mark"
      else
        printf '  ~/%s:%*s%s not found\n' "$name" $((14 - ${#name})) "" "$cross_mark"
      fi
    done
    echo ""

    # Notification tools
    echo "Notification tools:"
    case "$_CLI_ALERT_PLATFORM" in
      darwin)
        for tool in terminal-notifier osascript afplay say; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
      linux)
        for tool in notify-send paplay aplay espeak; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
      wsl|windows)
        for tool in powershell.exe wsl-notify-send; do
          local path
          path="$(command -v "$tool" 2>/dev/null || true)"
          if [[ -n "$path" ]]; then
            printf '  %-16s%s %s\n' "${tool}:" "$check_mark" "$path"
          else
            printf '  %-16s%s not found\n' "${tool}:" "$cross_mark"
          fi
        done
        ;;
    esac
    echo ""

    # Config
    echo "Config:"
    echo "  CLI_ALERT_ENABLED=$CLI_ALERT_ENABLED"
    echo "  CLI_ALERT_AUTO=${CLI_ALERT_AUTO:-true}"
    echo "  CLI_ALERT_THRESHOLD=${CLI_ALERT_THRESHOLD:-30}"
    echo "  CLI_ALERT_SOUND_SUCCESS=$CLI_ALERT_SOUND_SUCCESS"
    echo "  CLI_ALERT_SOUND_FAILURE=$CLI_ALERT_SOUND_FAILURE"
    echo "  CLI_ALERT_VOICE=${CLI_ALERT_VOICE:-<off>}"
    echo "  CLI_ALERT_DEBUG=${CLI_ALERT_DEBUG:-<off>}"
    echo "  CLI_ALERT_SOUND_TIMEOUT=${CLI_ALERT_SOUND_TIMEOUT:-10}"
    echo "  CLI_ALERT_FOCUS_DETECT=${CLI_ALERT_FOCUS_DETECT:-true}"
    echo "  CLI_ALERT_NOTIFY_ON=${CLI_ALERT_NOTIFY_ON:-all}"
    echo "  CLI_ALERT_ACTIVATE=${CLI_ALERT_ACTIVATE:-<auto-detect>}"
    echo "  CLI_ALERT_EXCLUDE=${CLI_ALERT_EXCLUDE:-vim nvim vi nano ...}"
    echo ""

    # Config file
    echo "Config file:"
    local config_file="${CLI_ALERT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/cli-alert/config}"
    if [[ -f "$config_file" ]]; then
      printf '  %s %s\n' "$check_mark" "$config_file"
    else
      printf '  %s not found (%s)\n' "$cross_mark" "$config_file"
    fi
    echo ""

    # History
    echo "History:"
    local log_file="${CLI_ALERT_HISTORY_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/cli-alert}/history.log"
    if [[ -f "$log_file" ]]; then
      local count
      count=$(wc -l < "$log_file" | tr -d ' ')
      printf '  %s %s (%s entries)\n' "$check_mark" "$log_file" "$count"
    else
      printf '  %s %s (not yet created)\n' "$cross_mark" "$log_file"
    fi
    echo ""

    # AI CLI hooks
    echo "AI CLI hooks:"
    local base_dir
    base_dir="$(cd "$(dirname "$0")/.." && pwd)"
    local ai_i
    for ai_i in "${!_CLI_ALERT_AI_NAMES[@]}"; do
      local ai_name="${_CLI_ALERT_AI_NAMES[$ai_i]}"
      local ai_label="${_CLI_ALERT_AI_LABELS[$ai_i]}"
      local ai_hook="${_CLI_ALERT_AI_HOOKS[$ai_i]}"
      local ai_cmd="${_CLI_ALERT_AI_CMDS[$ai_i]}"
      local ai_settings="${_CLI_ALERT_AI_SETTINGS[$ai_i]}"
      local ai_config_dir="${_CLI_ALERT_AI_CONFIGDIRS[$ai_i]}"

      # Aider: no hooks
      if [[ -z "$ai_hook" ]]; then
        if command -v "$ai_cmd" &>/dev/null; then
          printf '  %-14s %s detected (use: alert aider <prompt>)\n' "${ai_label}:" "$check_mark"
        else
          printf '  %-14s %s not detected\n' "${ai_label}:" "$cross_mark"
        fi
        continue
      fi

      # Check if AI CLI is present
      if ! command -v "$ai_cmd" &>/dev/null && [[ -z "$ai_config_dir" || ! -d "$ai_config_dir" ]]; then
        printf '  %-14s %s not detected\n' "${ai_label}:" "$cross_mark"
        continue
      fi

      # Check hook installation
      local hook_file="${base_dir}/hooks/${ai_hook}"
      local hook_installed=false

      # Copilot uses a file-based approach
      if [[ "$ai_name" == "copilot" ]]; then
        local copilot_hook="$HOME/.github/hooks/cli-alert-session-end.json"
        if [[ -f "$copilot_hook" ]] && grep -q "copilot-done" "$copilot_hook" 2>/dev/null; then
          hook_installed=true
        fi
      elif [[ -n "$ai_settings" && -f "$ai_settings" ]]; then
        local hook_basename
        hook_basename=$(basename "$hook_file")
        if grep -q "${hook_basename%.sh}" "$ai_settings" 2>/dev/null; then
          hook_installed=true
        fi
      fi

      # Check toggle state
      local ai_toggle_val
      ai_toggle_val="$(_cli_alert_state_read "$ai_name" 2>/dev/null)" || ai_toggle_val=""

      if $hook_installed; then
        if [[ "$ai_toggle_val" == "off" ]]; then
          printf '  %-14s %s installed (toggled off)\n' "${ai_label}:" "$check_mark"
        else
          printf '  %-14s %s installed\n' "${ai_label}:" "$check_mark"
        fi
      else
        printf '  %-14s %s not installed (run: cli-alert setup %s-hook)\n' "${ai_label}:" "$cross_mark" "$ai_name"
      fi
    done
    echo ""

    # External notifications
    echo "External notifications:"
    local has_external=""
    [[ -n "${CLI_ALERT_SLACK_WEBHOOK:-}" ]]   && has_external+="slack "
    [[ -n "${CLI_ALERT_DISCORD_WEBHOOK:-}" ]] && has_external+="discord "
    [[ -n "${CLI_ALERT_TELEGRAM_TOKEN:-}" ]]  && has_external+="telegram "
    [[ -n "${CLI_ALERT_EMAIL_TO:-}" ]]        && has_external+="email "
    [[ -n "${CLI_ALERT_WHATSAPP_TOKEN:-}" ]]  && has_external+="whatsapp "
    [[ -n "${CLI_ALERT_WEBHOOK_URL:-}" ]]     && has_external+="webhook "
    if [[ -n "$has_external" ]]; then
      printf '  Active channels: %s\n' "$has_external"
      local transport="none"
      if command -v curl &>/dev/null; then transport="curl"
      elif command -v wget &>/dev/null; then transport="wget"
      else transport="/dev/tcp (HTTP only)"
      fi
      printf '  HTTP transport:  %s\n' "$transport"
      printf '  Rate limit:      %ss\n' "${CLI_ALERT_RATE_LIMIT:-10}"
    else
      printf '  %s no channels configured (run "cli-alert webhook status" for details)\n' "$cross_mark"
    fi
    echo ""

    # Notification control (mute, toggle, schedule)
    echo "Notification control:"

    # Load state module
    local _state_lib="${CLI_ALERT_LIB}/state.sh"
    if [[ -f "$_state_lib" ]]; then
      unset _CLI_ALERT_STATE_LOADED
      source "$_state_lib"
    fi

    # Mute status
    local mute_until
    if mute_until="$(_cli_alert_state_read "mute_until" 2>/dev/null)"; then
      if [[ "$mute_until" == "0" ]]; then
        printf '  Mute:            muted indefinitely\n'
      else
        local now
        now=$(date +%s)
        if (( mute_until > now )); then
          local remaining=$(( mute_until - now ))
          local rem_str
          if (( remaining >= 3600 )); then
            rem_str="$(( remaining / 3600 ))h $(( (remaining % 3600) / 60 ))m"
          elif (( remaining >= 60 )); then
            rem_str="$(( remaining / 60 ))m"
          else
            rem_str="${remaining}s"
          fi
          printf '  Mute:            muted (%s remaining)\n' "$rem_str"
        else
          printf '  Mute:            not muted\n'
        fi
      fi
    else
      printf '  Mute:            not muted\n'
    fi

    # Toggle states
    local layer val indicator
    for layer in desktop sound voice; do
      val="$(_cli_alert_state_read "$layer" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-17s off  (toggled off)\n' "${layer}:"
      else
        printf '  %-17s on\n' "${layer}:"
      fi
    done

    # External channel toggles
    local -a ext_channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
    local -a ext_envvars=("CLI_ALERT_SLACK_WEBHOOK" "CLI_ALERT_DISCORD_WEBHOOK" "CLI_ALERT_TELEGRAM_TOKEN" "CLI_ALERT_EMAIL_TO" "CLI_ALERT_WHATSAPP_TOKEN" "CLI_ALERT_WEBHOOK_URL")
    local i
    for i in "${!ext_channels[@]}"; do
      layer="${ext_channels[$i]}"
      local envvar="${ext_envvars[$i]}"
      val="$(_cli_alert_state_read "$layer" 2>/dev/null)" || val=""
      if [[ -z "${!envvar:-}" ]]; then
        printf '  %-17s -    (not configured)\n' "${layer}:"
      elif [[ "$val" == "off" ]]; then
        printf '  %-17s off  (toggled off)\n' "${layer}:"
      else
        printf '  %-17s on\n' "${layer}:"
      fi
    done

    # Schedule
    local quiet_start quiet_end
    quiet_start="$(_cli_alert_state_read "quiet_start" 2>/dev/null)" || quiet_start=""
    quiet_end="$(_cli_alert_state_read "quiet_end" 2>/dev/null)" || quiet_end=""
    if [[ -n "$quiet_start" && -n "$quiet_end" ]]; then
      printf '  Schedule:        %s-%s\n' "$quiet_start" "$quiet_end"
    elif [[ -n "${CLI_ALERT_QUIET_HOURS:-}" ]]; then
      printf '  Schedule:        %s (env)\n' "$CLI_ALERT_QUIET_HOURS"
    else
      printf '  Schedule:        none\n'
    fi
  )
}

cmd_test_notify() {
  (
    unset _CLI_ALERT_LOADED
    source "${CLI_ALERT_LIB}/cli-alert.sh"
    # Bypass focus detection — this is an explicit test
    CLI_ALERT_FOCUS_DETECT=false
    echo "Sending test notification..."
    if _cli_alert_notify "cli-alert Test" "If you see this, notifications are working!" 0; then
      printf '\033[1;32m[cli-alert]\033[0m Notification sent! Check your notification center.\n'
    else
      printf '\033[1;31m[cli-alert]\033[0m Notification may have failed. Run "cli-alert status" to diagnose.\n'
    fi
  )
}

cmd_sounds() {
  (
    unset _CLI_ALERT_LOADED
    source "${CLI_ALERT_LIB}/cli-alert.sh"
    printf 'Available sounds for %s:\n\n' "$_CLI_ALERT_PLATFORM"
    case "$_CLI_ALERT_PLATFORM" in
      darwin)
        for f in /System/Library/Sounds/*.aiff; do
          [[ -f "$f" ]] || continue
          local name
          name="$(basename "$f" .aiff)"
          local marker=""
          [[ "$name" == "$CLI_ALERT_SOUND_SUCCESS" ]] && marker=" (success)"
          [[ "$name" == "$CLI_ALERT_SOUND_FAILURE" ]] && marker=" (failure)"
          printf '  %s%s\n' "$name" "$marker"
        done
        ;;
      linux)
        for f in /usr/share/sounds/freedesktop/stereo/*.oga; do
          [[ -f "$f" ]] || continue
          local name
          name="$(basename "$f" .oga)"
          local marker=""
          [[ "$name" == "$CLI_ALERT_SOUND_SUCCESS" ]] && marker=" (success)"
          [[ "$name" == "$CLI_ALERT_SOUND_FAILURE" ]] && marker=" (failure)"
          printf '  %s%s\n' "$name" "$marker"
        done
        ;;
      wsl|windows)
        printf '  Asterisk, Hand, Exclamation, Question\n'
        ;;
      *)
        echo "  No system sounds directory known for this platform."
        ;;
    esac
    printf '\nCurrent: success=%s, failure=%s\n' "$CLI_ALERT_SOUND_SUCCESS" "$CLI_ALERT_SOUND_FAILURE"
    printf 'Set via: export CLI_ALERT_SOUND_SUCCESS=Ping\n'
    printf 'Tip: Use a file path for custom sounds (e.g., /path/to/sound.wav)\n'
  )
}

cmd_exclude() {
  local action="${1:-list}"
  (
    unset _CLI_ALERT_LOADED
    source "${CLI_ALERT_LIB}/cli-alert.sh"
    local current="${CLI_ALERT_EXCLUDE:-vim nvim vi nano less more man top htop ssh tmux screen fg bg watch}"

    case "$action" in
      list)
        echo "Current exclusion list:"
        local item
        for item in $current; do
          printf '  %s\n' "$item"
        done
        echo ""
        printf 'Supports glob patterns (e.g., npm* matches npm, npx, etc.)\n'
        ;;
      add)
        local pattern="${2:-}"
        if [[ -z "$pattern" ]]; then
          echo >&2 "Usage: cli-alert exclude add <pattern>"
          exit 1
        fi
        printf 'Add to your shell config:\n\n'
        printf '  export CLI_ALERT_EXCLUDE="%s %s"\n\n' "$current" "$pattern"
        ;;
      remove)
        local pattern="${2:-}"
        if [[ -z "$pattern" ]]; then
          echo >&2 "Usage: cli-alert exclude remove <pattern>"
          exit 1
        fi
        local new_list=""
        local item
        for item in $current; do
          if [[ "$item" != "$pattern" ]]; then
            new_list="${new_list:+$new_list }$item"
          fi
        done
        printf 'Add to your shell config:\n\n'
        printf '  export CLI_ALERT_EXCLUDE="%s"\n\n' "$new_list"
        ;;
      *)
        echo >&2 "Usage: cli-alert exclude [list|add <pattern>|remove <pattern>]"
        exit 1
        ;;
    esac
  )
}

cmd_webhook() {
  local action="${1:-status}"
  (
    unset _CLI_ALERT_LOADED
    source "${CLI_ALERT_LIB}/cli-alert.sh"

    case "$action" in
      status)
        echo "External notifications:"

        # Transport
        local transport="none"
        if command -v curl &>/dev/null; then
          transport="curl ($(command -v curl))"
        elif command -v wget &>/dev/null; then
          transport="wget ($(command -v wget))"
        else
          transport="/dev/tcp (HTTP only, no HTTPS)"
        fi
        echo "  HTTP transport: $transport"
        echo "  Rate limit:     ${CLI_ALERT_RATE_LIMIT:-10}s"
        echo "  Timeout:        ${CLI_ALERT_WEBHOOK_TIMEOUT:-5}s"
        echo ""

        # Channel status
        local check_mark="✓" cross_mark="-"
        echo "  Channels:"
        if [[ -n "${CLI_ALERT_SLACK_WEBHOOK:-}" ]]; then
          printf '    %-12s%s configured\n' "Slack:" "$check_mark"
        else
          printf '    %-12s%s not configured (set CLI_ALERT_SLACK_WEBHOOK)\n' "Slack:" "$cross_mark"
        fi
        if [[ -n "${CLI_ALERT_DISCORD_WEBHOOK:-}" ]]; then
          printf '    %-12s%s configured\n' "Discord:" "$check_mark"
        else
          printf '    %-12s%s not configured (set CLI_ALERT_DISCORD_WEBHOOK)\n' "Discord:" "$cross_mark"
        fi
        if [[ -n "${CLI_ALERT_TELEGRAM_TOKEN:-}" ]]; then
          if [[ -n "${CLI_ALERT_TELEGRAM_CHAT_ID:-}" ]]; then
            printf '    %-12s%s configured\n' "Telegram:" "$check_mark"
          else
            printf '    %-12s%s token set but missing CLI_ALERT_TELEGRAM_CHAT_ID\n' "Telegram:" "$cross_mark"
          fi
        else
          printf '    %-12s%s not configured (set CLI_ALERT_TELEGRAM_TOKEN)\n' "Telegram:" "$cross_mark"
        fi
        if [[ -n "${CLI_ALERT_EMAIL_TO:-}" ]]; then
          local mailer="none"
          if command -v sendmail &>/dev/null; then mailer="sendmail"
          elif command -v mail &>/dev/null; then mailer="mail"
          fi
          printf '    %-12s%s configured (via %s)\n' "Email:" "$check_mark" "$mailer"
        else
          printf '    %-12s%s not configured (set CLI_ALERT_EMAIL_TO)\n' "Email:" "$cross_mark"
        fi
        if [[ -n "${CLI_ALERT_WHATSAPP_TOKEN:-}" ]]; then
          printf '    %-12s%s configured\n' "WhatsApp:" "$check_mark"
        else
          printf '    %-12s%s not configured (set CLI_ALERT_WHATSAPP_TOKEN)\n' "WhatsApp:" "$cross_mark"
        fi
        if [[ -n "${CLI_ALERT_WEBHOOK_URL:-}" ]]; then
          printf '    %-12s%s configured\n' "Webhook:" "$check_mark"
        else
          printf '    %-12s%s not configured (set CLI_ALERT_WEBHOOK_URL)\n' "Webhook:" "$cross_mark"
        fi
        ;;
      test)
        local channel="${2:-}"
        if [[ -z "$channel" ]]; then
          echo >&2 "Usage: cli-alert webhook test <channel>"
          echo >&2 "Channels: slack discord telegram email whatsapp webhook"
          exit 1
        fi

        # Load external module
        _cli_alert_load_external

        if ! declare -f _cli_alert_validate_channel &>/dev/null; then
          echo >&2 "cli-alert: external notification module not loaded"
          exit 1
        fi

        # Validate ALL required vars upfront
        local validation_error
        if ! validation_error=$(_cli_alert_validate_channel "$channel" 2>&1); then
          printf '\033[1;31m[cli-alert]\033[0m %s: %s\n' "$channel" "$validation_error" >&2
          exit 1
        fi

        local send_fn="_cli_alert_external_${channel}"
        if ! declare -f "$send_fn" &>/dev/null; then
          echo >&2 "cli-alert: unknown channel '$channel'"
          exit 1
        fi

        echo "Sending test to ${channel}..."
        _CLI_ALERT_SKIP_RATE_LIMIT=true

        if "$send_fn" "cli-alert Test" "If you receive this, your ${channel} integration is working!" 0; then
          printf '\033[1;32m[cli-alert]\033[0m Test sent successfully!'
          [[ -n "${_CLI_ALERT_LAST_HTTP_STATUS:-}" && "${_CLI_ALERT_LAST_HTTP_STATUS:-}" != "unknown" ]] && printf ' (HTTP %s)' "$_CLI_ALERT_LAST_HTTP_STATUS"
          printf '\n'
        else
          printf '\033[1;31m[cli-alert]\033[0m Test FAILED.'
          [[ -n "${_CLI_ALERT_LAST_HTTP_STATUS:-}" && "${_CLI_ALERT_LAST_HTTP_STATUS:-}" != "unknown" ]] && printf ' (HTTP %s)' "$_CLI_ALERT_LAST_HTTP_STATUS"
          printf '\n'
          printf '\033[1;33m[cli-alert]\033[0m Run with CLI_ALERT_EXTERNAL_DEBUG=true for details.\n'
          exit 1
        fi
        ;;
      *)
        echo >&2 "Usage: cli-alert webhook [status|test <channel>]"
        exit 1
        ;;
    esac
  )
}

cmd_history() {
  local action="${1:-show}"
  local log_dir="${CLI_ALERT_HISTORY_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/cli-alert}"
  local log_file="${log_dir}/history.log"

  case "$action" in
    show|"")
      if [[ ! -f "$log_file" ]]; then
        echo "No notification history found."
        echo "  Log file: $log_file"
        return 0
      fi
      local count="${2:-20}"
      echo "Recent notifications (last $count):"
      echo ""
      printf '%-19s  %-4s  %-30s  %s\n' "TIMESTAMP" "EXIT" "TITLE" "CHANNELS"
      printf '%-19s  %-4s  %-30s  %s\n' "-------------------" "----" "------------------------------" "--------"
      tail -n "$count" "$log_file" | while IFS=$'\t' read -r ts title msg exit_code channels; do
        printf '%-19s  %-4s  %-30s  %s\n' "$ts" "$exit_code" "$title" "$channels"
      done
      echo ""
      echo "Log file: $log_file"
      ;;
    --clear)
      if [[ -f "$log_file" ]]; then
        rm -f "$log_file"
        echo "History cleared."
      else
        echo "No history file to clear."
      fi
      ;;
    --path)
      echo "$log_file"
      ;;
    *)
      echo >&2 "Usage: cli-alert history [show [N]|--clear|--path]"
      exit 1
      ;;
  esac
}

cmd_config() {
  local action="${1:-show}"
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/cli-alert"
  local config_file="${CLI_ALERT_CONFIG:-${config_dir}/config}"

  case "$action" in
    show|"")
      echo "Config file: $config_file"
      if [[ -f "$config_file" ]]; then
        echo "Status: loaded"
        echo ""
        echo "Contents:"
        cat "$config_file"
      else
        echo "Status: not found"
        echo ""
        echo "To create a config file:"
        echo "  mkdir -p \"$config_dir\""
        echo "  cli-alert config init > \"$config_file\""
      fi
      ;;
    init)
      cat <<'CONFIGEOF'
# cli-alert configuration
# Sourced on startup. Env vars set before "cli-alert init" override these.
# Use :="${VAR:=value}" so explicit env vars take precedence.

# Master switch
: "${CLI_ALERT_ENABLED:=true}"

# Auto-notify for long commands
: "${CLI_ALERT_AUTO:=true}"
: "${CLI_ALERT_THRESHOLD:=30}"

# Notification filter: all, failure, success
: "${CLI_ALERT_NOTIFY_ON:=all}"

# Sound names or file paths
# : "${CLI_ALERT_SOUND_SUCCESS:=Glass}"
# : "${CLI_ALERT_SOUND_FAILURE:=Sosumi}"

# TTS announcements
# : "${CLI_ALERT_VOICE:=true}"

# Focus detection
: "${CLI_ALERT_FOCUS_DETECT:=true}"

# Notification history
: "${CLI_ALERT_HISTORY:=true}"

# Commands to exclude (space-separated, supports globs)
# : "${CLI_ALERT_EXCLUDE:=vim nvim vi nano less more man top htop ssh tmux screen fg bg alert-bg watch}"

# macOS: app to switch to when clicking notification (auto-detected from $TERM_PROGRAM)
# Requires terminal-notifier: brew install terminal-notifier
# Common values: com.microsoft.VSCode, com.apple.Terminal, com.googlecode.iterm2
# : "${CLI_ALERT_ACTIVATE:=}"

# Quiet hours (HH:MM-HH:MM, crosses midnight OK)
# : "${CLI_ALERT_QUIET_HOURS:=22:00-08:00}"

# External channels (uncomment and fill in):
# export CLI_ALERT_SLACK_WEBHOOK="https://hooks.slack.com/services/..."
# export CLI_ALERT_DISCORD_WEBHOOK="https://discord.com/api/webhooks/..."
# export CLI_ALERT_TELEGRAM_TOKEN="..."
# export CLI_ALERT_TELEGRAM_CHAT_ID="..."
# export CLI_ALERT_EMAIL_TO="you@example.com"
# export CLI_ALERT_WEBHOOK_URL="https://your-endpoint.com/hook"
CONFIGEOF
      ;;
    edit)
      if [[ ! -f "$config_file" ]]; then
        echo >&2 "Config file does not exist. Create it first:"
        echo >&2 "  mkdir -p \"$config_dir\" && cli-alert config init > \"$config_file\""
        exit 1
      fi
      "${EDITOR:-${VISUAL:-vi}}" "$config_file"
      ;;
    path)
      echo "$config_file"
      ;;
    *)
      echo >&2 "Usage: cli-alert config [show|init|edit|path]"
      exit 1
      ;;
  esac
}

_load_state_module() {
  if [[ -z "${_CLI_ALERT_STATE_LOADED:-}" ]]; then
    local _state_lib="${CLI_ALERT_LIB}/state.sh"
    if [[ -f "$_state_lib" ]]; then
      source "$_state_lib"
    else
      echo >&2 "cli-alert: state module not found"
      exit 1
    fi
  fi
}

cmd_mute() {
  _load_state_module
  local duration_str="${1:-}"

  if [[ -z "$duration_str" ]]; then
    # Mute indefinitely
    _cli_alert_state_write "mute_until" "0"
    printf '\033[1;32m[cli-alert]\033[0m Muted indefinitely. Run "cli-alert unmute" to resume.\n'
  else
    local seconds
    if ! seconds="$(_cli_alert_parse_duration "$duration_str")"; then
      echo >&2 "Usage: cli-alert mute [duration]  (e.g., 30m, 2h, 1h30m)"
      exit 1
    fi
    local until_ts
    until_ts=$(( $(date +%s) + seconds ))
    _cli_alert_state_write "mute_until" "$until_ts"

    # Format expiry for display (portable: try GNU date -d, then BSD date -r)
    local expiry_str
    if expiry_str=$(date -d "@${until_ts}" '+%H:%M:%S' 2>/dev/null); then
      true
    elif expiry_str=$(date -r "${until_ts}" '+%H:%M:%S' 2>/dev/null); then
      true
    else
      expiry_str="epoch ${until_ts}"
    fi
    printf '\033[1;32m[cli-alert]\033[0m Muted for %s (until %s)\n' "$duration_str" "$expiry_str"
  fi
}

cmd_unmute() {
  _load_state_module
  _cli_alert_state_delete "mute_until"
  printf '\033[1;32m[cli-alert]\033[0m Unmuted. Notifications resumed.\n'
}

cmd_toggle() {
  _load_state_module
  local layer="${1:-}" explicit="${2:-}"

  local -a valid_layers=(sound desktop voice slack discord telegram email whatsapp webhook claude codex gemini copilot cursor)

  if [[ -z "$layer" ]]; then
    # Show all toggle states
    echo "Toggle states:"
    local l val
    for l in desktop sound voice; do
      val="$(_cli_alert_state_read "$l" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${l}:"
      else
        printf '  %-12s on\n' "${l}:"
      fi
    done

    # External channels with configured indicator
    local -a ext_channels=("slack" "discord" "telegram" "email" "whatsapp" "webhook")
    local -a ext_envvars=("CLI_ALERT_SLACK_WEBHOOK" "CLI_ALERT_DISCORD_WEBHOOK" "CLI_ALERT_TELEGRAM_TOKEN" "CLI_ALERT_EMAIL_TO" "CLI_ALERT_WHATSAPP_TOKEN" "CLI_ALERT_WEBHOOK_URL")
    local i
    for i in "${!ext_channels[@]}"; do
      l="${ext_channels[$i]}"
      local envvar="${ext_envvars[$i]}"
      val="$(_cli_alert_state_read "$l" 2>/dev/null)" || val=""
      if [[ -z "${!envvar:-}" ]]; then
        printf '  %-12s -    (not configured)\n' "${l}:"
      elif [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${l}:"
      else
        printf '  %-12s on   (configured)\n' "${l}:"
      fi
    done

    # AI CLI hooks
    echo ""
    echo "AI CLI hooks:"
    local ai_i
    for ai_i in "${!_CLI_ALERT_AI_NAMES[@]}"; do
      local ai_name="${_CLI_ALERT_AI_NAMES[$ai_i]}"
      local ai_hook="${_CLI_ALERT_AI_HOOKS[$ai_i]}"
      local ai_cmd="${_CLI_ALERT_AI_CMDS[$ai_i]}"
      local ai_config_dir="${_CLI_ALERT_AI_CONFIGDIRS[$ai_i]}"

      # Skip Aider (no hooks, no toggle)
      [[ -z "$ai_hook" ]] && continue

      # Check if detected
      if ! command -v "$ai_cmd" &>/dev/null && [[ -z "$ai_config_dir" || ! -d "$ai_config_dir" ]]; then
        printf '  %-12s -    (not detected)\n' "${ai_name}:"
        continue
      fi

      val="$(_cli_alert_state_read "$ai_name" 2>/dev/null)" || val=""
      if [[ "$val" == "off" ]]; then
        printf '  %-12s off  (toggled off)\n' "${ai_name}:"
      else
        printf '  %-12s on\n' "${ai_name}:"
      fi
    done
    return 0
  fi

  # Handle "external" group
  if [[ "$layer" == "external" ]]; then
    local target="${explicit:-}"
    if [[ -z "$target" ]]; then
      # Flip: if any external is on, turn all off; otherwise all on
      local any_on=false
      for l in slack discord telegram email whatsapp webhook; do
        val="$(_cli_alert_state_read "$l" 2>/dev/null)" || val=""
        [[ "$val" != "off" ]] && any_on=true && break
      done
      if $any_on; then target="off"; else target="on"; fi
    fi
    for l in slack discord telegram email whatsapp webhook; do
      if [[ "$target" == "on" ]]; then
        _cli_alert_state_delete "$l"
      else
        _cli_alert_state_write "$l" "off"
      fi
    done
    printf '\033[1;32m[cli-alert]\033[0m All external channels: %s\n' "$target"
    return 0
  fi

  # Validate layer name
  local found=false
  for l in "${valid_layers[@]}"; do
    [[ "$l" == "$layer" ]] && found=true && break
  done
  if ! $found; then
    echo >&2 "cli-alert: unknown layer '$layer'"
    echo >&2 "Valid layers: ${valid_layers[*]} external"
    exit 1
  fi

  if [[ -n "$explicit" ]]; then
    # Explicit on/off
    case "$explicit" in
      on)
        _cli_alert_state_delete "$layer"
        printf '\033[1;32m[cli-alert]\033[0m %s: on\n' "$layer"
        ;;
      off)
        _cli_alert_state_write "$layer" "off"
        printf '\033[1;32m[cli-alert]\033[0m %s: off\n' "$layer"
        ;;
      *)
        echo >&2 "Usage: cli-alert toggle <layer> [on|off]"
        exit 1
        ;;
    esac
  else
    # Flip current state
    local current
    current="$(_cli_alert_state_read "$layer" 2>/dev/null)" || current=""
    if [[ "$current" == "off" ]]; then
      _cli_alert_state_delete "$layer"
      printf '\033[1;32m[cli-alert]\033[0m %s: on\n' "$layer"
    else
      _cli_alert_state_write "$layer" "off"
      printf '\033[1;32m[cli-alert]\033[0m %s: off\n' "$layer"
    fi
  fi
}

cmd_schedule() {
  _load_state_module
  local input="${1:-}"

  if [[ -z "$input" ]]; then
    # Show current schedule
    local quiet_start quiet_end
    quiet_start="$(_cli_alert_state_read "quiet_start" 2>/dev/null)" || quiet_start=""
    quiet_end="$(_cli_alert_state_read "quiet_end" 2>/dev/null)" || quiet_end=""
    if [[ -n "$quiet_start" && -n "$quiet_end" ]]; then
      printf 'Quiet hours: %s-%s\n' "$quiet_start" "$quiet_end"
    elif [[ -n "${CLI_ALERT_QUIET_HOURS:-}" ]]; then
      printf 'Quiet hours: %s (from env)\n' "$CLI_ALERT_QUIET_HOURS"
    else
      echo "No schedule set."
    fi
    return 0
  fi

  if [[ "$input" == "off" ]]; then
    _cli_alert_state_delete "quiet_start"
    _cli_alert_state_delete "quiet_end"
    printf '\033[1;32m[cli-alert]\033[0m Schedule cleared.\n'
    return 0
  fi

  # Validate HH:MM-HH:MM format
  if [[ ! "$input" =~ ^([0-9]{2}:[0-9]{2})-([0-9]{2}:[0-9]{2})$ ]]; then
    echo >&2 "Usage: cli-alert schedule [HH:MM-HH:MM|off]"
    echo >&2 "Example: cli-alert schedule 22:00-08:00"
    exit 1
  fi

  local start="${BASH_REMATCH[1]}" end="${BASH_REMATCH[2]}"

  # Validate hours and minutes
  local start_h="${start%%:*}" start_m="${start##*:}"
  local end_h="${end%%:*}" end_m="${end##*:}"
  if (( 10#$start_h > 23 || 10#$start_m > 59 || 10#$end_h > 23 || 10#$end_m > 59 )); then
    echo >&2 "cli-alert: invalid time in schedule"
    exit 1
  fi

  _cli_alert_state_write "quiet_start" "$start"
  _cli_alert_state_write "quiet_end" "$end"
  printf '\033[1;32m[cli-alert]\033[0m Quiet hours set: %s-%s\n' "$start" "$end"
}

cmd_help() {
  cat <<'HELP'
cli-alert — Terminal process completion notifier

Usage:
  cli-alert init [bash|zsh]     Output shell init code (use with eval)
  cli-alert setup [all|ai-hooks|<ai>-hook]  Configure shell + AI CLI hooks
  cli-alert uninstall           Remove shell integration + all AI hooks
  cli-alert status              Show diagnostic info and verify setup
  cli-alert test-notify         Send a test notification
  cli-alert sounds              List available system sounds
  cli-alert exclude [list|add|remove]  Manage auto-notify exclusion list
  cli-alert webhook [status|test <channel>]  External notification channels
  cli-alert history [show [N]|--clear|--path]  View notification history
  cli-alert config [show|init|edit|path]  Manage config file
  cli-alert mute [duration]     Mute all notifications (e.g., 30m, 2h)
  cli-alert unmute              Resume notifications
  cli-alert toggle [layer [on|off]]  Toggle notification layers
  cli-alert schedule [HH:MM-HH:MM|off]  Set daily quiet hours
  cli-alert test                Run verification tests
  cli-alert version [--verbose] Show version (--verbose for details)
  cli-alert help                Show this help

Quick start:
  # Add to your .zshrc or .bashrc:
  eval "$(cli-alert init zsh)"

  # Or auto-configure everything:
  cli-alert setup

After init, you get:
  alert [--on-failure|--on-success] <command>   Wrap command with notifications
  alert-bg [PID|%jobspec]       Monitor background job and notify on completion
  (auto-notify)                 Commands >30s auto-notify on completion

AI CLI hooks:
  cli-alert setup ai-hooks         Install hooks for all detected AI CLIs
  cli-alert setup claude-hook      Install Claude Code Stop hook
  cli-alert setup codex-hook       Install Codex CLI hook
  cli-alert setup gemini-hook      Install Gemini CLI hook
  cli-alert setup copilot-hook     Install Copilot CLI hook
  cli-alert setup cursor-hook      Install Cursor hook
  cli-alert toggle claude off      Disable notifications from Claude
  cli-alert toggle codex off       Disable notifications from Codex

  Aider: no native hooks — use: alert aider <prompt>

Config file:
  Create with: cli-alert config init > ~/.config/cli-alert/config

Config (env vars, set before eval):
  CLI_ALERT_ENABLED=true        Master on/off switch
  CLI_ALERT_AUTO=true           Auto-notify on/off
  CLI_ALERT_THRESHOLD=30        Seconds before auto-notify triggers
  CLI_ALERT_NOTIFY_ON=all       Notify filter: all, failure, success
  CLI_ALERT_SOUND_SUCCESS=Glass Success sound name or file path
  CLI_ALERT_SOUND_FAILURE=Sosumi Failure sound name or file path
  CLI_ALERT_VOICE=true          Enable TTS announcements
  CLI_ALERT_EXCLUDE="vim ssh"   Commands to skip (supports globs like npm*)
  CLI_ALERT_DEBUG=true          Enable debug output to stderr
  CLI_ALERT_SOUND_TIMEOUT=10    Max seconds to wait for sound playback
  CLI_ALERT_FOCUS_DETECT=true   Suppress notifications when terminal focused
  CLI_ALERT_ACTIVATE=...        macOS: bundle ID to activate on notification click (auto-detect)
  CLI_ALERT_TERMINALS="..."     Custom terminal app names for focus detection
  CLI_ALERT_HISTORY=true        Log notifications to history file

Notification control:
  cli-alert mute 30m            Mute all for 30 minutes
  cli-alert mute                Mute indefinitely
  cli-alert unmute              Resume notifications
  cli-alert toggle sound off    Disable sound, keep desktop popups
  cli-alert toggle slack off    Disable Slack channel
  cli-alert toggle external off Disable all external channels
  cli-alert toggle claude off   Disable Claude Code notifications
  cli-alert schedule 22:00-08:00  Set quiet hours (crosses midnight OK)
  cli-alert schedule off        Clear quiet hours
  CLI_ALERT_QUIET_HOURS=22:00-08:00  Env var fallback for quiet hours

  Layers: desktop, sound, voice, slack, discord, telegram, email,
          whatsapp, webhook, external (group),
          claude, codex, gemini, copilot, cursor (AI CLIs)

External notifications (env vars):
  CLI_ALERT_SLACK_WEBHOOK=...   Slack incoming webhook URL
  CLI_ALERT_DISCORD_WEBHOOK=... Discord webhook URL
  CLI_ALERT_TELEGRAM_TOKEN=...  Telegram bot token (also set _CHAT_ID)
  CLI_ALERT_EMAIL_TO=...        Email recipient (requires sendmail/mail)
  CLI_ALERT_WHATSAPP_TOKEN=...  Twilio auth (also set _API_URL, _FROM, _TO)
  CLI_ALERT_WEBHOOK_URL=...     Generic webhook endpoint
  CLI_ALERT_RATE_LIMIT=10       Min seconds between external notifications
  CLI_ALERT_WEBHOOK_TIMEOUT=5   HTTP timeout in seconds
HELP
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

case "${1:-help}" in
  init)        shift; cmd_init "$@" ;;
  setup)       shift; cmd_setup "$@" ;;
  uninstall)   shift; cmd_uninstall "$@" ;;
  status)      shift; cmd_status "$@" ;;
  test-notify) shift; cmd_test_notify "$@" ;;
  sounds)      shift; cmd_sounds "$@" ;;
  exclude)     shift; cmd_exclude "$@" ;;
  webhook)     shift; cmd_webhook "$@" ;;
  history)     shift; cmd_history "$@" ;;
  config)      shift; cmd_config "$@" ;;
  mute)        shift; cmd_mute "$@" ;;
  unmute)      shift; cmd_unmute "$@" ;;
  toggle)      shift; cmd_toggle "$@" ;;
  schedule)    shift; cmd_schedule "$@" ;;
  test)        shift; cmd_test "$@" ;;
  version|--version|-v) shift 2>/dev/null; cmd_version "$@" ;;
  help|--help|-h)       cmd_help ;;
  *)
    echo >&2 "cli-alert: unknown command '$1'"
    echo >&2 "Run 'cli-alert help' for usage"
    exit 1
    ;;
esac
