<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>shelldone</id>
    <version>1.4.0</version>
    <title>shelldone</title>
    <authors>Naresh Sekar</authors>
    <projectUrl>https://github.com/nareshnavinash/shelldone</projectUrl>
    <licenseUrl>https://github.com/nareshnavinash/shelldone/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Terminal process completion notifier. Sends OS-native desktop notifications and sounds when long-running terminal commands complete. Cross-platform: macOS, Linux, WSL, Windows (Git Bash).</description>
    <tags>cli notification terminal bash zsh productivity alert sound desktop-notification slack discord telegram webhook cross-platform wsl automation devtools</tags>
  </metadata>
  <files>
    <file src="bin\shelldone" target="tools\bin\shelldone" />
    <file src="lib\*.sh" target="tools\lib" />
    <file src="lib\*.bash" target="tools\lib" />
    <file src="lib\*.zsh" target="tools\lib" />
    <file src="hooks\*.sh" target="tools\hooks" />
    <file src="completions\shelldone.bash" target="tools\completions\shelldone.bash" />
    <file src="completions\shelldone.zsh" target="tools\completions\shelldone.zsh" />
    <file src="VERSION" target="tools\VERSION" />
    <file src="LICENSE" target="tools\LICENSE" />
    <file src="packaging\chocolatey\tools\chocolateyInstall.ps1" target="tools\chocolateyInstall.ps1" />
    <file src="packaging\chocolatey\tools\chocolateyUninstall.ps1" target="tools\chocolateyUninstall.ps1" />
  </files>
</package>
